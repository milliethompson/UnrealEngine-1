Begin Class Name=Krall
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//=============================================================================
// Krall.
//=============================================================================
class Krall expands ScriptedPawn
	package(UnGame);

#exec MESH IMPORT MESH=Krall ANIVFILE=\UNREAL\MODELS\kralla.3D DATAFILE=\UNREAL\MODELS\kralld.3D X=0 Y=0 Z=0
#exec MESH ORIGIN MESH=Krall X=70 Y=350 Z=-80 YAW=64

#exec MESH SEQUENCE MESH=krall SEQ=All          STARTFRAME=0   NUMFRAMES=424
#exec MESH SEQUENCE MESH=krall SEQ=Breath       STARTFRAME=0   NUMFRAMES=29
#exec MESH SEQUENCE MESH=krall SEQ=Die1         STARTFRAME=29  NUMFRAMES=45
#exec MESH SEQUENCE MESH=krall SEQ=Fighter      STARTFRAME=74  NUMFRAMES=1
#exec MESH SEQUENCE MESH=krall SEQ=Hit          STARTFRAME=75  NUMFRAMES=14
#exec MESH SEQUENCE MESH=krall SEQ=Look         STARTFRAME=89  NUMFRAMES=44
#exec MESH SEQUENCE MESH=krall SEQ=Shoot1       STARTFRAME=133 NUMFRAMES=24
#exec MESH SEQUENCE MESH=krall SEQ=Shoot2       STARTFRAME=157 NUMFRAMES=44
#exec MESH SEQUENCE MESH=krall SEQ=Stand        STARTFRAME=201 NUMFRAMES=1
#exec MESH SEQUENCE MESH=krall SEQ=Strike1      STARTFRAME=202 NUMFRAMES=20
#exec MESH SEQUENCE MESH=krall SEQ=Strike2      STARTFRAME=222 NUMFRAMES=23
#exec MESH SEQUENCE MESH=krall SEQ=Strike3      STARTFRAME=245 NUMFRAMES=29
#exec MESH SEQUENCE MESH=krall SEQ=T1           STARTFRAME=274 NUMFRAMES=4
#exec MESH SEQUENCE MESH=krall SEQ=T2           STARTFRAME=278 NUMFRAMES=9
#exec MESH SEQUENCE MESH=krall SEQ=T3           STARTFRAME=287 NUMFRAMES=14
#exec MESH SEQUENCE MESH=krall SEQ=T4           STARTFRAME=301 NUMFRAMES=9
#exec MESH SEQUENCE MESH=krall SEQ=Throw        STARTFRAME=310 NUMFRAMES=49
#exec MESH SEQUENCE MESH=krall SEQ=Twirl        STARTFRAME=359 NUMFRAMES=34
#exec MESH SEQUENCE MESH=krall SEQ=Walk         STARTFRAME=393 NUMFRAMES=29
#exec MESH SEQUENCE MESH=krall SEQ=Footup       STARTFRAME=422 NUMFRAMES=1

#exec TEXTURE IMPORT NAME=krall FILE=\UNREAL\MODELS\krall.PCX FAMILY=Skins FLAGS=2

#exec MESHMAP NEW   MESHMAP=krall MESH=krall 
#exec MESHMAP SCALE MESHMAP=krall X=0.08 Y=0.08 Z=0.16

#exec MESHMAP SETTEXTURE MESHMAP=krall NUM=1 TEXTURE=krall

//FIXME - make these final?
function PlayWaiting()
	{
	local float decision;
	local float animspeed;
	animspeed = 0.5 + 0.5 * FRand(); //fixme - add to all creatures
	decision = FRand();
	if (!bool(NextAnim)) //pick first waiting animation
		NextAnim = Breath;
		
	LoopAnim(NextAnim, animspeed);
	log("Next krall waiting anim is "$nextanim);
	if (NextAnim == 'Breath')
		{
		Alertness = 0.0;
		if (decision < 0.2)
			NextAnim = Look;
		}
	else if (NextAnim == 'Look')
		{
		Alertness = 1.0;
		if (decision < 0.3) 
			NextAnim = Twirl;
		else 
			NextAnim = Breath;
 		}
 	else if (NextAnim == 'Twirl')
 		{
 		Alertness = 0.0;
 		if (decision < 0.5) 
			NextAnim = Twirl;
		else 
			NextAnim = Breath;
 		}
		
	}

function PlayPatrolStop()
	{
	local float decision;
	local float animspeed;
	animspeed = 0.5 + 0.5 * FRand(); //fixme - add to all creatures
	decision = FRand();
	if (!bool(NextAnim)) //pick first waiting animation
		NextAnim = Breath;
		
	LoopAnim(NextAnim, animspeed);
	log("Next krall patrolstop anim is "$nextanim);
	if (NextAnim == 'Breath')
		{
		Alertness = 0.0;
		if (decision < 0.4)
			NextAnim = Look;
		}
	else if (NextAnim == 'Look')
		{
		Alertness = 1.0;
		if (decision < 0.3) 
			NextAnim = Twirl;
		else 
			NextAnim = Breath;
 		}
 	else if (NextAnim == 'Twirl')
 		{
 		Alertness = 0.0;
 		if (decision < 0.5) 
			NextAnim = Twirl;
		else 
			NextAnim = Breath;
 		}
		
	}
	
	
function PlayWaitingGuard()
	{
	NextState = Waiting;
	PlayWaiting();
	}

function PlayWaitingAmbush()
	{
	if (FRand() < 0.4)
		LoopAnim('Look', 0.3);
	else 
		LoopAnim('Breath');
	Alertness = 1.0;
	}

function PlayFighter()
	{
	LoopAnim(T1);
	}

function PlayMovingAttack()
{
	bReadyToAttack = true; //so he'll smoothly switch to melee
	PlayAnim('Shoot2');
	if (FRand() < 0.3)
		{
		NextState = 'Charging'; //FIXME - generalize
		bReadyToAttack = false;
		SetTimer(TimeBetweenAttacks  * (1.0 + FRand()),false); //FIXME single spot (function)
		}

}

function PlayRunning()
{
	LoopAnim('Walk', -1.0/GroundSpeed,true,0.3);
}

function PlayThreatening()
{
	local float decision;
	local float animspeed;
	decision = FRand();
	
	animspeed = 0.5 + 0.5 * FRand(); //fixme - add to all creatures
	decision = FRand();
	if (!bool(NextAnim)) //pick first waiting animation
		NextAnim = Breath;
		
	LoopAnim(NextAnim, animspeed);
	log("Next krall threatening anim is "$nextanim);
	
	if ((NextAnim != 'Breath') || (decision < 0.3))
		{
		decision = FRand();
		if (decision < 0.35)
			NextAnim = 'Breath';
		else if (decision < 0.55)
			NextAnim = 'Twirl';
		else if (decision < 0.8)
			NextAnim = 'T3';
		else if (decision < 0.9)
			NextAnim = 'Strike1';
		else 
			NextAnim = 'Strike2'; 
		}
	else
		NextAnim = 'Breath';	
}

function PlayTurning()
{
	PlayFighter();
}

function PlayDying()
{
	PlayAnim('Die1');
}

function PlayTakeHit()
{
	PlayAnim('Hit');
}

//FIXME - put this into the victory dance state?
//Also - need to be able to acquire enemies during victory dance
//(at least if shot)
function PlayVictoryDance()
{
	PlayFighter();
}
	
function SpawnShot()
{
	local actor Proj;
	local rotation FireRotation;
	local vector X,Y,Z;
	GetAxes(Rotation,X,Y,Z);
	
	FireRotation = Rotation;
	FireRotation.Yaw = FireRotation.Yaw + 3500 * FRand() - 1750;
	Log("Play ranged attack");
	//improve random direction error - based on creature attackAccuracy (add instancevar) - 	skill effect!!!
	//FIXME - place projectile accurately and on correct frame
	Proj = spawn(SkaarjProjectile,None,NoName,
		(Location + 1.2 * CollisionRadius * X - 0.5 * CollisionRadius * Y),FireRotation);
	if( Proj != None )
		{
		Proj.instigator = Self;
		}
}

//also change accuracy based on enemy normal velocity, and own accuracy
state MeleeAttack
{
ignores SeePlayer, HearNoise;

function PlayMeleeAttack()
{
	local int hitdamage;
	local float TargetDist, decision;
	local vector TargetDir;
	If (FRand() < 0.2) //FIXME - base on skill
		PlayAnim('T3');
	else
		{
		TargetDir = Normal(Target.Location - Location);
		TargetDist = Size(Target.Location - Location);
		hitdamage = 20;  //fixme make this an instance variable
		decision = FRand();
		 if (decision < 0.25)
			PlayAnim('Strike1'); 
	 	else if (decision < 0.5)
	   		PlayAnim('Strike2');
	 	else if (decision < 0.75)
	 		PlayAnim('Strike3');
	 	else
	 		{
	 		PlayAnim('Throw'); //FIXME - do this right
	  		Target.Velocity += vector(Rotation) * 100; 
			Target.Velocity.Z = 300;
	 		Target.Rotation.Pitch = 8192;
	 		}		
		//FIXME - coordinate damage with correct frame
		DamageTarget(hitdamage);
		}
}

engine function AnimEnd() 
{
	PlayMeleeAttack();
	if (Size(Target.Location - Location) > (MeleeRange + Target.CollisionRadius + CollisionRadius)) 
		GotoState(Attacking, SetAttackTimer);
	else if (Pawn(Target) != None)
		if (Pawn(Target).Health < 0)
			GotoState(Attacking, SetAttackTimer);
	
}

Begin:
	Log(class$" Melee Attack");
	if (AnimRate == 0.0) PlayMeleeAttack();
FaceTarget:
	MoveToward(Target);
	Goto(FaceTarget);
}

state RangedAttack
{
ignores SeePlayer, HearNoise;

function PlayRangedAttack()
{
	local int hitdamage;
	local vector X,Y,Z;
	GetAxes(Rotation,X,Y,Z);

	if (Normal(Target.Location - Location) Dot X < 0.98) //keep turning
		PlayTurning(); //FIXME - turning anim
	else
		{	
		Log("Play ranged attack");
		hitdamage = 15;
			//Also add random error - based on creature attackAccuracy (add instancevar)
		PlayAnim('Shoot1'); //FIXME - damage on correct frame
		//RayDamageTarget(hitdamage, X);
		SpawnShot();
		}
}

engine function AnimEnd() 
{
	PlayRangedAttack();
	If (FRand() < 0.6) //FIXME base on skill and instance var
		GotoState(Attacking, SetAttackTimer);
}

Begin:
	Acceleration = vect(0,0,0); //stop
	Log(class$" Ranged Attack");
	if (AnimRate == 0.0) PlayRangedAttack();
FaceTarget:
	TurnToward(Target);
	Goto(FaceTarget);
}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      bHasRangedAttack=True
      bMovingRangedAttack=True
      Visibility=128
      AttitudeToPlayer=ATTITUDE_Threaten
      SeqWaitingToFighter=T1
      SeqFighterToWaiting=T2
      SeqFighterToMoving=T3
      SeqMovingToFighter=T4
      GroundSpeed=+00200.000000
      WaterSpeed=+00100.000000
      AirSpeed=+00100.000000
      AccelRate=+00500.000000
      JumpZ=+00300.000000
      DrawType=DT_Mesh
      Mesh=Krall
      CollisionHeight=+00044.000000
      Mass=+00150.000000
      RotationSpeed=50000
   End DefaultProperties
End Class

