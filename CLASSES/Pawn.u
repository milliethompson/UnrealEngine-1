Begin Class Name=Skaarj
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//=============================================================================
// Skaarj.
//=============================================================================
class Skaarj expands ScriptedPawn
	package(UnGame);
	
#exec MESH IMPORT MESH=Skaarj ANIVFILE=\UNREAL\MODELS\ANIV17.3D DATAFILE=\UNREAL\MODELS\DATA17.3D X=0 Y=0 Z=0
#exec MESH ORIGIN MESH=Skaarj X=0 Y=0 Z=00 YAW=64

#exec MESH SEQUENCE MESH=Skaarj SEQ=All  STARTFRAME=0  NUMFRAMES=335

#exec MESH SEQUENCE MESH=Skaarj SEQ=Squat        STARTFRAME=1   NUMFRAMES=40
#exec MESH SEQUENCE MESH=Skaarj SEQ=Blade        STARTFRAME=39  NUMFRAMES=35
#exec MESH SEQUENCE MESH=Skaarj SEQ=Claw        STARTFRAME=74  NUMFRAMES=19
#exec MESH SEQUENCE MESH=Skaarj SEQ=Death        STARTFRAME=93  NUMFRAMES=44
#exec MESH SEQUENCE MESH=Skaarj SEQ=Fighter      STARTFRAME=137 NUMFRAMES=1
#exec MESH SEQUENCE MESH=Skaarj SEQ=Headup       STARTFRAME=138 NUMFRAMES=20
#exec MESH SEQUENCE MESH=Skaarj SEQ=Firing       STARTFRAME=159 NUMFRAMES=19
#exec MESH SEQUENCE MESH=Skaarj SEQ=Looking      STARTFRAME=179 NUMFRAMES=44
#exec MESH SEQUENCE MESH=Skaarj SEQ=Jog          STARTFRAME=223 NUMFRAMES=20
#exec MESH SEQUENCE MESH=Skaarj SEQ=Lunge        STARTFRAME=243 NUMFRAMES=34
#exec MESH SEQUENCE MESH=Skaarj SEQ=Spin         STARTFRAME=277 NUMFRAMES=19
#exec MESH SEQUENCE MESH=Skaarj SEQ=T1           STARTFRAME=296 NUMFRAMES=4
#exec MESH SEQUENCE MESH=Skaarj SEQ=T2           STARTFRAME=300 NUMFRAMES=9
#exec MESH SEQUENCE MESH=Skaarj SEQ=T3           STARTFRAME=309 NUMFRAMES=4
#exec MESH SEQUENCE MESH=Skaarj SEQ=T4           STARTFRAME=313 NUMFRAMES=4
#exec MESH SEQUENCE MESH=Skaarj SEQ=T5           STARTFRAME=317 NUMFRAMES=14
#exec MESH SEQUENCE MESH=Skaarj SEQ=T6           STARTFRAME=331 NUMFRAMES=4

#exec TEXTURE IMPORT NAME=Skaarj1 FILE=\UNREAL\MODELS\Texture2.PCX FAMILY=Skins FLAGS=2
#exec TEXTURE IMPORT NAME=Skaarj2 FILE=\UNREAL\MODELS\Texture4.PCX FAMILY=Skins PALETTE=Skaarj1 FLAGS=2

#exec MESHMAP NEW   MESHMAP=Skaarj MESH=Skaarj 
#exec MESHMAP SCALE MESHMAP=Skaarj X=0.09 Y=0.09 Z=0.18

#exec MESHMAP SETTEXTURE MESHMAP=Skaarj NUM=1 TEXTURE=Skaarj1 
#exec MESHMAP SETTEXTURE MESHMAP=Skaarj NUM=3 TEXTURE=Skaarj2
//-----------------------------------------------------------------------------
// Skaarj variables.

// Sounds.
var() sound 
	LungeSound,		// Sound made when Skaarj lunges.
	SpinSound,		// Sound made when Skaarj does spin.
	ClawSound,		// Sound made when Skaarj claws.
	ShootSound;		// Sound made when Skaarj shoots.

// Attack damage.
var() byte
	LungeDamage,	// Basic damage done by lunge.
	SpinDamage,		// Basic damage done by spin.
	ClawDamage,		// Basic damage done by each claw.
	ShootDamage;	// Basic damage caused by shooting.

//Skaarj animations
//FIXME - make these final?
function PlayWaiting()
	{
	local float decision;
	local float animspeed;
	animspeed = 0.5 + 0.5 * FRand(); //fixme - add to all creatures

	decision = FRand();
	if (!bool(NextAnim)) //pick first waiting animation
		NextAnim = Squat;
		
	LoopAnim(NextAnim, animspeed);
	log("Next skaarj waiting anim is "$nextanim);
	if (NextAnim == 'Headup')
		{
		NextAnim = Looking;
		Alertness = 0.0;
		}
	else if (NextAnim == 'Looking')
		{
		Alertness = 1.0;
		if (decision < 0.65)
			NextAnim = Squat;
		}
	else if (NextAnim == 'Squat')
		{
		Alertness = -0.5;
		if (decision < 0.3) 
			NextAnim = Blade;
		else if (decision < 0.55)
			NextAnim = Headup;
 		}
	else if (NextAnim == 'Blade')
		{
		Alertness = -0.5;
		if (decision < 0.65) 
			NextAnim = Squat;
		}
	
	}

function PlayPatrolStop()
	{
	PlayFighter();	
	}

function PlayWaitingGuard()
	{
	NextState = Waiting;
	PlayWaiting();
	}

function PlayWaitingAmbush()
	{
	Alertness = 1.0;
	LoopAnim(Fighter);
	/*
	if (FRand() < 0.4)
		LoopAnim(Headup, 0.2);
	else 
		LoopAnim(Looking, 0.5);*/
	}

function PlayFighter()
	{
	LoopAnim(T1);
	}

function PlayRunning()
{
	LoopAnim(Jog, -1.0/GroundSpeed,true, 0.3);
}

function PlayThreatening()
{
	PlayFighter();
}

function PlayTurning()
{
	PlayFighter();
}

function PlayDying()
{
	PlayAnim(Death);
}

function PlayTakeHit()
{
	PlayFighter();
}

function SpawnLeftShot()
{
	local actor Proj;
	local rotation FireRotation;
	local vector X,Y,Z;
	GetAxes(Rotation,X,Y,Z);
	
	FireRotation = Rotation;
	FireRotation.Yaw = FireRotation.Yaw + 1500 * FRand() - 750;
	Log("Play ranged attack");
	//improve random direction error - based on creature attackAccuracy (add instancevar) - 	skill effect!!! - more error if firing while moving
	Proj = spawn(SkaarjProjectile,None,NoName,
		(Location + 1.2 * CollisionRadius * X + 0.5 * CollisionRadius * Y),FireRotation);
	if( Proj != None )
		{
		Proj.instigator = Self;
		} 
}

function SpawnRightShot()
{
	local actor Proj;
	local rotation FireRotation;
	local vector X,Y,Z;
	GetAxes(Rotation,X,Y,Z);
	
	FireRotation = Rotation;
	FireRotation.Yaw = FireRotation.Yaw + 1500 * FRand() - 750;
	Log("Play ranged attack");
	//improve random direction error - based on creature attackAccuracy (add instancevar) - 	skill effect!!!
	//FIXME - place projectile accurately and on correct frame
	Proj = spawn(SkaarjProjectile,None,NoName,
		(Location + 1.2 * CollisionRadius * X - 0.5 * CollisionRadius * Y),FireRotation);
	if( Proj != None )
		{
		Proj.instigator = Self;
		} 
}

//FIXME - put this into the victory dance state?
//Also - need to be able to acquire enemies during victory dance
//(at least if shot)
function PlayVictoryDance()
{
	PlayFighter();
}
	

//also change accuracy based on enemy normal velocity, and own accuracy
state MeleeAttack
{
ignores SeePlayer, HearNoise;

function PlayMeleeAttack()
{
	local int hitdamage;
	local float TargetDist;
	local vector TargetDir;
	TargetDir = Normal(Target.Location - Location);
	TargetDist = Size(Target.Location - Location);
	hitdamage = 20;  //fixme make this an instance variable
	If (TargetDist <= (CollisionRadius + Target.CollisionRadius + CollisionRadius))
 		PlayAnim(Spin); 
 	else
 		{
 		Velocity = Velocity + AccelRate * TargetDir; //instant acceleration in that direction
 		PlayAnim(Lunge);
 		}
	//FIXME - coordinate damage with correct frame
	DamageTarget(hitdamage);
}

engine function AnimEnd() 
{
	PlayMeleeAttack();
	if (Size(Target.Location - Location) > (MeleeRange + Target.CollisionRadius + CollisionRadius)) 
		GotoState(Attacking, SetAttackTimer);
	else if (Pawn(Target) != None)
		if (Pawn(Target).Health < 0)
			GotoState(Attacking, SetAttackTimer);

}

Begin:
	Log(class$" Melee Attack");
	if (AnimRate == 0.0) PlayMeleeAttack();
FaceTarget:
	MoveToward(Target);
	Goto(FaceTarget);
}

state RangedAttack
{
ignores SeePlayer, HearNoise;

function PlayRangedAttack()
{
	local int hitdamage;
	local vector X,Y,Z;
	GetAxes(Rotation,X,Y,Z);

	if (Normal(Target.Location - Location) Dot X < 0.98) //keep turning
		PlayTurning(); //FIXME - turning anim
	else
		{	
		Log("Play ranged attack");
		hitdamage = 15;
			//Also add random error - based on creature attackAccuracy (add instancevar)

		PlayAnim(Firing); //FIXME - damage on correct frame
		SpawnLeftShot();
		SpawnRightShot();
		}
}

engine function AnimEnd() 
{
	PlayRangedAttack();
	If (FRand() < 0.6) //FIXME base on skill and instance var
		GotoState(Attacking, SetAttackTimer);
}

Begin:
	Acceleration = vect(0,0,0); //stop
	Log(class$" Ranged Attack");
	if (AnimRate == 0.0) PlayRangedAttack();
FaceTarget:
	TurnToward(Target);
	Goto(FaceTarget);
}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      LungeSound=None
      SpinSound=None
      ClawSound=None
      ShootSound=None
      LungeDamage=25
      SpinDamage=20
      ClawDamage=20
      ShootDamage=11
      bCanPossess=False
      bHasRangedAttack=True
      Visibility=128
      MeleeRange=+00080.000000
      BaseAggressiveness=+00001.000000
      Intelligence=BRAINS_HUMAN
      SeqWaitingToFighter=T1
      SeqFighterToWaiting=T2
      SeqFighterToMoving=T6
      SeqMovingToFighter=T5
      GroundSpeed=+00400.000000
      WaterSpeed=+00180.000000
      AccelRate=+00200.000000
      JumpZ=+00000.000000
      DrawType=DT_Mesh
      Mesh=Skaarj
      CollisionRadius=+00040.000000
      CollisionHeight=+00046.000000
      Mass=+00200.000000
      RotationSpeed=50000
   End DefaultProperties
End Class

Begin Class Name=Brute
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//=============================================================================
// Brute.
//=============================================================================
class Brute expands ScriptedPawn
	package(UnGame);

#exec MESH IMPORT MESH=BigMan ANIVFILE=\Unreal\Models\ANIV58.3D DATAFILE=\Unreal\Models\DATA58.3D X=0 Y=0 Z=0
#exec MESH ORIGIN MESH=BigMan X=-46 Y=120 Z=-170 YAW=64

#exec MESH SEQUENCE MESH=BigMan SEQ=All          STARTFRAME=0   NUMFRAMES=411
#exec MESH SEQUENCE MESH=BigMan SEQ=StillLook    STARTFRAME=0   NUMFRAMES=50
#exec MESH SEQUENCE MESH=BigMan SEQ=StillFire    STARTFRAME=50  NUMFRAMES=20
#exec MESH SEQUENCE MESH=BigMan SEQ=PistolWhip   STARTFRAME=70  NUMFRAMES=20
#exec MESH SEQUENCE MESH=BigMan SEQ=Sleep        STARTFRAME=90  NUMFRAMES=30
#exec MESH SEQUENCE MESH=BigMan SEQ=GutShot      STARTFRAME=120 NUMFRAMES=35
#exec MESH SEQUENCE MESH=BigMan SEQ=Die          STARTFRAME=155 NUMFRAMES=36
#exec MESH SEQUENCE MESH=BigMan SEQ=ShootLeft    STARTFRAME=191 NUMFRAMES=23
#exec MESH SEQUENCE MESH=BigMan SEQ=Walk         STARTFRAME=213 NUMFRAMES=45
#exec MESH SEQUENCE MESH=BigMan SEQ=WalkLeft     STARTFRAME=213 NUMFRAMES=22
#exec MESH SEQUENCE MESH=BigMan SEQ=WalkRight    STARTFRAME=235 NUMFRAMES=23
#exec MESH SEQUENCE MESH=BigMan SEQ=ShootRight   STARTFRAME=258 NUMFRAMES=22
#exec MESH SEQUENCE MESH=BigMan SEQ=T1           STARTFRAME=280 NUMFRAMES=25
#exec MESH SEQUENCE MESH=BigMan SEQ=T2           STARTFRAME=305 NUMFRAMES=19
#exec MESH SEQUENCE MESH=BigMan SEQ=T3           STARTFRAME=324 NUMFRAMES=16
#exec MESH SEQUENCE MESH=BigMan SEQ=T4           STARTFRAME=340 NUMFRAMES=15
#exec MESH SEQUENCE MESH=BigMan SEQ=T5           STARTFRAME=355 NUMFRAMES=5
#exec MESH SEQUENCE MESH=BigMan SEQ=TakeHit      STARTFRAME=360 NUMFRAMES=10
#exec MESH SEQUENCE MESH=BigMan SEQ=Die2         STARTFRAME=370 NUMFRAMES=41

#exec TEXTURE IMPORT NAME=BigMan1 FILE=\Unreal\Models\BigMan1.PCX FAMILY="Skins"
#exec TEXTURE IMPORT NAME=BigMan2 FILE=\Unreal\Models\BigMan2.PCX FAMILY="Skins" Palette=BigMan1


#exec MESHMAP NEW   MESHMAP=BigMan MESH=BigMan 
#exec MESHMAP SCALE MESHMAP=BigMan X=0.1 Y=0.1 Z=0.2



#exec MESHMAP SETTEXTURE MESHMAP=BigMan NUM=0 TEXTURE=BigMan1 
#exec MESHMAP SETTEXTURE MESHMAP=BigMan NUM=4 TEXTURE=BigMan2

//-----------------------------------------------------------------------------
// Brute variables.

// Sounds.
var() sound
	ShootSound,	    // Sound made when monster shoots.
	WhipSound;      // Sound made during pistol-whip.

// Attack damage.
var() byte
	ShootDamage,	// Basic damage done by each shot.
	WhipDamage;		// Basic damage done by pistol-whip.

function PlayWaiting()
	{
	local float decision;
	local float animspeed;
	animspeed = 0.5 + 0.5 * FRand(); //fixme - add to all creatures

	decision = FRand();
	if (!bool(NextAnim)) //pick first waiting animation
		NextAnim = Sleep;
		
	LoopAnim(NextAnim, animspeed);
	log("Next brute waiting anim is "$nextanim);
	if (NextAnim == 'Sleep')
		{
		Alertness = -1.0;
		if (decision < 0.1)
			NextAnim = StillLook;
		}
	else if (NextAnim == 'StillLook')
		{
		Alertness = 1.0;
		NextAnim = Sleep;
 		}
	}

function PlayPatrolStop()
	{
	local float decision;
	local float animspeed;
	animspeed = 0.5 + 0.5 * FRand(); //fixme - add to all creatures

	decision = FRand();
	if (!bool(NextAnim)) //pick first waiting animation
		NextAnim = Sleep;
		
	LoopAnim(NextAnim, animspeed);
	log("Next brute waiting anim is "$nextanim);
	if (NextAnim == 'Sleep')
		{
		Alertness = 0.0;
		if (decision < 0.4)
			NextAnim = StillLook;
		}
	else if (NextAnim == 'StillLook')
		{
		Alertness = 1.0;
		NextAnim = Sleep;
 		}
	}

function PlayWaitingGuard()
	{
	NextState = Waiting;
	PlayWaiting();
	}

function PlayWaitingAmbush()
	{
	Alertness = 1.0;
	LoopAnim(StillLook, 0.3);
	}

function PlayFighter()
	{
	LoopAnim(T1);
	}

function PlayRunning()
{
	LoopAnim(Walk, -1.0/GroundSpeed,true,0.3);
}

function PlayThreatening()
{
	PlayFighter();
}

function PlayTurning()
{
	PlayRunning();
}

function PlayDying()
{
	if (FRand() < 0.5)
		PlayAnim(Die);
	else
		PlayAnim(Die2);
}

function PlayTakeHit()
{
	PlayAnim(TakeHit);
}

function PlayMovingAttack()
{
	bReadyToAttack = true; //so he'll smoothly switch to melee
	if (!bool(NextAnim))
		NextAnim = ShootLeft;
	
	PlayAnim(NextAnim);
	
	if (NextAnim == 'ShootLeft')
		{
		SpawnLeftShot();
		NextAnim = ShootRight;
		}
	else if (NextAnim == 'ShootRight')
		{
		SpawnRightShot();
		if (FRand() < 0.7)
			NextAnim = ShootLeft;
		else
			NextAnim = WalkLeft;
		}
	else if (NextAnim == 'WalkLeft')
		{
		NextState = 'Charging'; //FIXME - generalize
		bReadyToAttack = false;
		SetTimer(TimeBetweenAttacks  * (1.0 + FRand()),false); //FIXME single spot (function)
		PlayRunning();
		Disable('AnimEnd');
		}
}

//FIXME - put this into the victory dance state?
//Also - need to be able to acquire enemies during victory dance
//(at least if shot)
function PlayVictoryDance()
{
	PlayFighter();
}
	
function SpawnLeftShot()
{
	local actor Proj;
	local rotation FireRotation;
	local vector X,Y,Z;
	GetAxes(Rotation,X,Y,Z);
	
	FireRotation = Rotation;
	FireRotation.Yaw = FireRotation.Yaw + 3500 * FRand() - 1750;
	Log("Play ranged attack");
	//improve random direction error - based on creature attackAccuracy (add instancevar) - 	skill effect!!! - more error if firing while moving
/*	Proj = spawn(BruteProjectile ,None,NoName,
		(Location + 1.2 * CollisionRadius * X + 0.5 * CollisionRadius * Y),FireRotation);
	if( Proj != None )
		{
		Proj.instigator = Self;
		} */
}

function SpawnRightShot()
{
	local actor Proj;
	local rotation FireRotation;
	local vector X,Y,Z;
	GetAxes(Rotation,X,Y,Z);
	
	FireRotation = Rotation;
	FireRotation.Yaw = FireRotation.Yaw + 3500 * FRand() - 1750;
	Log("Play ranged attack");
	//improve random direction error - based on creature attackAccuracy (add instancevar) - 	skill effect!!!
	//FIXME - place projectile accurately and on correct frame
/*	Proj = spawn(BruteProjectile,None,NoName,
		(Location + 1.2 * CollisionRadius * X - 0.5 * CollisionRadius * Y),FireRotation);
	if( Proj != None )
		{
		Proj.instigator = Self;
		} */
}

//also change accuracy based on enemy normal velocity, and own accuracy
state MeleeAttack
{
ignores SeePlayer, HearNoise;

function PlayMeleeAttack()
{
	local int hitdamage;
	local float TargetDist;
	local vector TargetDir;
	TargetDir = Normal(Target.Location - Location);
	TargetDist = Size(Target.Location - Location);
	hitdamage = 20;  //fixme make this an instance variable
	If (FRand() < 0.5)
 		PlayAnim(GutShot); 
 	else
 		{
  		PlayAnim(PistolWhip);
 		}
	//FIXME - coordinate damage with correct frame
	DamageTarget(hitdamage);
}

engine function AnimEnd() 
{
	PlayMeleeAttack();
	if (Size(Target.Location - Location) > (MeleeRange + Target.CollisionRadius + CollisionRadius)) 
		GotoState(Attacking, SetAttackTimer);
	else if (Pawn(Target) != None)
		if (Pawn(Target).Health < 0)
			GotoState(Attacking, SetAttackTimer);

}

Begin:
	Log(class$" Melee Attack");
	if (AnimRate == 0.0) PlayMeleeAttack();
FaceTarget:
	TurnToward(Target);
	Goto(FaceTarget);
}

state RangedAttack
{
ignores SeePlayer, HearNoise;

function PlayRightShot()
	{
	SpawnRightShot(); 
	MakeNoise(1.0); //FIXME - set appropriate loudness
	PlayAnim(StillFire); //FIXME - need animation notification to spawnshots!!!!
	}

function PlayLeftShot()
	{
	SpawnLeftShot(); 
	MakeNoise(1.0); //FIXME - set appropriate loudness
	PlayAnim(StillFire); 
	}

engine function AnimEnd() 
	{
	if (NextAnim == 'RightShot')
		{
		PlayRightShot();
		NextAnim = 'LeftShot';
		}
	else //left shot
		{
		PlayLeftShot();
		NextAnim = 'RightShot';
		If (FRand() < 0.1) //FIXME base on skill
			GotoState(Attacking, SetAttackTimer);
		}
	}

Begin:
	NextAnim = 'RightShot';
	Acceleration = vect(0,0,0); //stop
	Log(class$" Ranged Attack");
	if (AnimRate == 0.0) PlayRightShot();
	
FaceTarget:
	TurnToward(Target);
	Goto(FaceTarget);
}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
