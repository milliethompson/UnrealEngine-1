Begin Class Name=FireflySwarm
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//=============================================================================
// FireflySwarm.
//=============================================================================
class FireflySwarm expands ScriptedPawn;

var() byte swarmsize; //number of fireflies in swarm

//FIXME add stasis mode

auto state wandering
{
function addflies()
	{
	local actor newfly;
	local int num;
	num = swarmsize;
	while (num > 0)
		{
		num -= 1;
		newfly = spawn(firefly,None,NoName, Location + VRand() * CollisionRadius);
		newfly.setowner(self);
		}
	}
	
engine function timer (int ticks)
	{
	gotostate('wandering','newdir');
	}

Begin:
	addflies();

Newdir:
	MoveTo(300 * VRand());
}		
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      swarmsize=0
   End DefaultProperties
End Class

