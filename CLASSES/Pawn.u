}

//=============================================================================
// Inventory related functions.

// Add Item to this pawn's inventory and send the appropriate 
// PickupNotify messages. Returns true if successfully added, false if not.
function bool AddInventory( inventory NewItem )
{
	// Skip if already in the inventory.
	local inventory Inv;
	for( Inv=Inventory; Inv!=None; Inv=Inv.Inventory )
		if( Inv == NewItem )
			return false;

	// Notify each of our existing inventory items of the pickup.
	// An item may choose to destroy the newly-picked up item.			
	for( Inv=Inventory; Inv!=None; Inv=Inv.Inventory )
		if( Inv.PickupNotify(NewItem) )
			return false;

	// The item should not have been destroyed if we get here.
	assert(NewItem!=None);

	// Add to front of inventory chain.
	NewItem.SetOwner(Self);
	NewItem.Inventory = Inventory;
	Inventory = NewItem;
	return true;
}

// Remove Item from this pawn's inventory, if it exists.
// Returns true if it existed and was deleted, false if it did not exist.
function bool DeleteInventory( inventory Item )
{
	// If this item is in our inventory chain, unlink it.
	local actor Link;
	for( Link = Self; Link!=None; Link=Link.Inventory )
	{
		if( Link.Inventory == Item )
		{
			Link.Inventory = Item.Inventory;
			break;
		}
	}
}

// Called when this pawn he has a chance to pick Item up (i.e. when 
// the pawn touches a weapon pickup). The pawn should return true if 
// he wants to pick it up, false if he does not want it.
//
// Note that Item is not in this pawn's inventory when this function is 
// called, and this pawn should not do anything with Item.
function bool PickupQuery( inventory Item )
{
	// Don't accept it if we already have one.
	local inventory Inv;
	for( Inv=Inventory; Inv!=None; Inv=Inv.Inventory )
		if( Inv.Class == Item.Class )
			return false;

	// Allow any of our inventory items to preempt the pickup.			
	for( Inv=Inventory; Inv!=None; Inv=Inv.Inventory )
		if( Inv.PreemptPickupQuery(Item) )
			return false;

	// Accept it.
	return true;
}

// Activate NewWeapon in this pawn's inventory.
// If NewWeapon is None, just deactivates the current weapon.
// Returns true if activated, false if not.
function bool ActivateWeapon( weapon NewWeapon )
{
return false;
}

// Return the best weapon for this pawn to use. This is called when the 
// current weapon runs out and a new one needs to be selected.
function weapon ChooseWeapon()
{
log("choose weapon");
}

//=============================================================================
// Inventory-related input notifications.

// The player wants to switch to weapon group numer I.
function ServerWeapon( float F, name N, string[255] S )
{
	log( Class $ ": ServerWeapon" );
}
	
// The player wants to switch to the previous weapon group.
function ServerPrevWeapon( float F, name N, string[255] S )
{
	log( Class $ ": ServerPrevWeapon" );
}

// The player wants to switch to the next weapon group.
function ServerNextWeapon( float F, name N, string[255] S )
{
	log( Class $ ": ServerNextWeapon" );
}

// The player wants to fire.
function ServerFire( float F, name N, string[255] S )
{
	if( Weapon!=None )
		Weapon.Fire(1.0);
	//else - if I've possessed a creature, use its attack
}

// The player wants to alternate-fire.
function ServerAltFire( float F, name N, string[255] S )
{
	if( Weapon!=None )
		Weapon.AltFire(1.0);
}

// Display inventory.
function ServerDebugInv( float F, name N, string[255] S )
{
	local inventory Inv;
	log( "DebugInv " $ Class );
	log( "   Weapon: " $ Weapon.Class );
	for( Inv=Inventory; Inv!=None; Inv=Inv.Inventory )
		log( "   Inventory: " $ Inv.Class );
}

engine function Bump(actor Other)
{
	log(Other.class$" bumped "$class);
	if (Enemy == Other)
		bReadyToAttack = True; //can melee right away
	SetEnemy(Pawn(Other));
}

engine function HearNoise(float Loudness, Actor NoiseMaker)
{
	local Vector HearingError;
	if(NoisePerceived(NoiseMaker,Loudness))
		{
		HearingError = Max(500 - Stimulus, 0.0) * VRand();
		HearingError.Z = 0.0;
		if (Pawn(NoiseMaker) != None)
			{
			if (SetEnemy(Pawn(NoiseMaker)))
				LastSeenPos = NoiseMaker.Location + HearingError; 
			}
		else if (NoiseMaker.instigator != None) 
			{
			if (SetEnemy(NoiseMaker.instigator))
				LastSeenPos = NoiseMaker.Location + HearingError;
			} 
		}
					
}

engine function SeePlayer(Actor SeenPlayer)
{
	//Check if in FOV
	Log(class$" has line of sight to player");
	
	if (Pawn(SeenPlayer).Health > 0)
		{
		InFieldOfView(SeenPlayer); // set stimulus
		if (stimulus > 0.0)
			{
			Log(class$" sees player!");
			if (SetEnemy(Pawn(SeenPlayer)))
				LastSeenPos = SeenPlayer.Location;
			}
		}
	Enable('AnimEnd');		
}

engine function Die()
{
	Log(class$" got a message to die");
	GoToState(Dying);			
}

engine function Damage( int Damage, Actor instigatedBy, Vector hitlocation, 
						Vector momentum)
{
	Enable('AnimEnd'); //FIXME - smoothly go back to next animation 
	//e.g. check in state's animend if current sequence is SeqTakeHit, if so do transition
	//(only in subclass implementations)
	  
	Stimulus = 1.0;
	Health -= Damage;
	Log(class$" took damage - health is "$health);
	Velocity += momentum/Mass; 
	Physics = PHYS_Falling;  
	NextAnim = NoName;
	if (Health <= 0) GoToState(Dying);
	else 
	{
	if (Pawn(instigatedBy) != None)
		{
		if(Pawn(instigatedBy).bIsPlayer) //change attitude to player
			{ //FIXME - also frenzy or run away against non-players
			if ((Health < 30) && 
					(Aggressiveness * FRand() + BaseAggressiveness * FRand() > 0.5))	
				{
				AttitudeToPlayer = ATTITUDE_Frenzy;
				Aggressiveness = 1.0;
				}
			else if (AttitudeToPlayer == ATTITUDE_Ignore) AttitudeToPlayer = ATTITUDE_Hate;
			else if (AttitudeToPlayer == ATTITUDE_Threaten) AttitudeToPlayer = ATTITUDE_Hate;
			else if (AttitudeToPlayer == ATTITUDE_Friendly) AttitudeToPlayer = ATTITUDE_Threaten;
			}
		SetEnemy(Pawn(instigatedBy)); 
		}

	if (Damage > 0.1 * Health)
		{
		NextAnim = 'TakeHit';
		PlayTakeHit(); 
		}
	}	
	MakeNoise(1.0); //FIXME - set appropriate loudness 

}

engine function Falling()
	{
		Physics = PHYS_Falling;
		log(class$" Falling");
	}
	
engine function Landed()
	{
		Physics = PHYS_Walking;
		log(class$" Landed");
	}

engine function HitWall(vector HitNormal)
	{
		Log(class$" hit wall with normal "$HitNormal);
	}
		
function bool SetEnemy( Pawn NewEnemy )
{
	local bool result;
	local eAttitude newAttitude;
	local bool noOldEnemy;
	noOldEnemy = (Enemy == None);
	
	result = false;
	newAttitude = AttitudeTo(NewEnemy);
	log ("Attitude to potential enemy is "$newAttitude);
	if ((noOldEnemy) && (newAttitude < ATTITUDE_Ignore))
		{
		result = true;
		Enemy = NewEnemy;
		}
	else if (newAttitude == ATTITUDE_Friendly) //your enemy is my enemy
		{
		log("noticed a friend");
		if (bool(NewEnemy.Enemy) && (noOldEnemy || (AttitudeTo(Enemy) > ATTITUDE_Frenzy)))
			{
			result = true;
			log("his enemy is my enemy");
			Enemy = NewEnemy.Enemy;
			if (Enemy.bIsPlayer)
				AttitudeToPlayer = NewEnemy.AttitudeTo(Enemy);
			}
		}
	else if (Enemy == NewEnemy)
		result = true;
	else if (newAttitude < AttitudeTo(Enemy))
		{
		result = true;
		OldEnemy = Enemy;
		Enemy = NewEnemy;
		}

	if (result)
		{
		log(class$" has new enemy - "$enemy.class);
		if (NoOldEnemy) //just acquired an enemy	
			{
			log(Class$" just acquired an enemy");
			NextState = Acquisition;
			Disable('SeePlayer');
			Disable('HearNoise');
			Enable('AnimEnd');
			MakeNoise(1.0);
			}
		}
	return result;
}
	
/* InFieldOfView
 Check if actor is in field of view (adjusted for sightradius and alertness)
Note - be sure to initialize Alertness to appropriate value in any state which calls this
function
*/

function int InFieldOfView(Actor seen)
{
	local int result;
	local float FOV;
	local float viewDist;
	local float sightDist;
	if (Enemy == seen)
		sightDist = SightRadius * ((Pawn(seen)).visibility + 32) * 0.015;
	else
		sightDist = SightRadius * (Pawn(seen)).visibility * 0.0083125;
		
	result = 0;
	//FIXME -try to just check sign first
	//reduce up/down visibility
	viewDist = size(seen.Location - Location);
	if (viewDist > SightDist)
		Stimulus = 0.0;
	else
		{
		FOV = Normal(seen.Location - Location) Dot Vector(Rotation);
		Stimulus = FOV - PeripheralVision + 0.707 * (Alertness + SightRadius/(viewDist * viewDist)); //FIXME - assumes excellent sightradius = 4000
		Stimulus = Stimulus - viewDist/SightRadius; 
		}
	//log(class$" FOV = "$FOV);
	if (Stimulus > 0.0)
 		result = 1;
 		
 	if (result == 1) 
 		log("target in FOV "$FOV);
 
 	return result;
}

/* NoisePerceived
//FIXME - provide some hearing out of line of sight? (maybe PVS)
// Reaction depends on creature hearing, distance to noise, noise loudness
Note - be sure to initialize Alertness to appropriate value in any state which calls this
function
//add randomness
*/
function bool NoisePerceived(Actor Noisemaker, Float loudness)
{
	local float perceived;
	local bool result;
	result = false;

	log(class$" listening for noise");	
	perceived =  Loudness/Size(NoiseMaker.Location - Location); //FIXME use square of distance?
	Stimulus = perceived - (1 - Alertness) * HearingThreshold;	
	if (Stimulus > 0.0)
		result = true;
	
	return result;	
}

/* RelativeStrength()
returns a value indicating the relative strength of other
0.0 = equal to self
> 0 stronger than self
< 0 weaker than self

Since the result will be compared to the creature's aggressiveness, it should have a magnitude
on the order of 0 to 2

Assess based on health, armor, weapon, location, presence of teammates
(but NOT aggressiveness)
FIXME - add other components
*/

function float RelativeStrength(Pawn Other)
{
	local float compare;
	
	compare = (Other.health - health) * 0.01;
	log(other.class$" relative strength to "$class$" is "$compare);
	return compare;
}
	
/* AttitudeTo
Returns the creature's attitude towards another Pawn
FIXME - add support for team membership in determination of attitude
*/

final function eAttitude AttitudeTo(Pawn Other)
{
	if (Other.bIsPlayer)
		{
		if (Intelligence > BRAINS_None)
		if ((AttitudeToPlayer == ATTITUDE_Hate) || (AttitudeToPlayer == ATTITUDE_Threaten) 
				|| (AttitudeToPlayer == ATTITUDE_Fear)) //check if afraid 
			{
			if (RelativeStrength(Other) > BaseAggressiveness + 0.2)
				AttitudeToPlayer = ATTITUDE_Fear;
			else if (AttitudeToPlayer == ATTITUDE_Fear)
				AttitudeToPlayer = ATTITUDE_Hate;
			}
		return AttitudeToPlayer;
		}
	else if (bIsPlayer)
		return Other.AttitudeToPlayer;
	else
		return AttitudeToCreature(Other); 
}

/* AttitudeToCreature
Typically implemented in subclass
*/

function eAttitude AttitudeToCreature(Pawn Other)
{
	if (Other.Class == Class)
		return ATTITUDE_Friendly;
	else
		return ATTITUDE_Ignore;
}


//=============================================================================
// Player Control

// Player view.
// Compute the rendering viewpoint for the player.
//
engine function PlayerCalcView( out vector CameraLocation, out rotation CameraRotation )
{
	local Actor HitActor;
	local vector View,HitLocation,HitNormal, Vel2D;
	local float ViewDist, WallOutDist;
	local float speed;

	// View rotation.
	CameraRotation = ViewRotation;

	if( bBehindView ) //up and behind (for death scene)
	{
	    ViewDist    = 100;
		WallOutDist = 30;
		View = vect(1,0,0) >> CameraRotation;
		if( Trace( HitLocation, HitNormal, Location - (ViewDist+WallOutDist) * vector(CameraRotation), Location ) != None )
			ViewDist = Min( (Location - HitLocation) Dot View, ViewDist );
		CameraLocation -= (ViewDist - WallOutDist) * View;
	}
	else
	{
		// First-person view.
		CameraLocation = Location;
		CameraLocation.Z += EyeHeight;

		If (Physics == PHYS_Walking)
		{
			//add bobbing when walking
			//FIXME - bob amplitude and rate should be pawn vars (for different creatures)
			Vel2D = Velocity;
			Vel2D.Z = 0.0;
			speed = Size(Vel2D);
			CameraLocation.Z += Bob * speed * speed * sin(8.0 *
			 						Level.TimeSeconds );
	
			//FIXME - if walking, look up/down stairs
		}
	}
}

//Player Jumped
engine function ServerJump( float F, name N, string[255] S )
	{
		if (Physics == PHYS_Walking)
		{
			Physics = PHYS_Falling;
			Velocity.Z = JumpZ; 
			log("Player Jumped! "$JumpZ);
		}
		//else if (Physics == PHYS_Swimming) //move up
			
	}

engine function ServerFly( float F, name N, string[255] S )
{
	GotoState(CheatFlying);
}

engine function ServerWalk( float F, name N, string[255] S )
{	
	SetCollision(true, true , true);
	Physics = PHYS_Falling;
	bCollideWorld = true;
	GotoState(PlayerWalking);	
}

engine function ServerGhost( float F, name N, string[255] S )
{
	SetCollision(false, false, false);
	bCollideWorld = false;
	GotoState(CheatFlying);
}

/* UpdateEyeHeight()
Called separately from player tick because physics is done after player tick
(to optimize responsiveness)
*/
engine function UpdateEyeHeight(float DeltaTime)
{
		local float smooth;
		smooth = 8.0;
		// Update eye height.
		// smooth up stairs
		If (Physics == PHYS_Walking)
			EyeHeight = (EyeHeight - Location.Z + OldLocation.Z) * (1 - smooth * deltaTime) +
							BaseEyeHeight * smooth * deltaTime;
		else
			EyeHeight = EyeHeight * ( 1 - smooth * deltaTime) +
							BaseEyeHeight * smooth * deltaTime;
	
		//FIXME - clamp max eyeheight
		if (EyeHeight < -0.5 * CollisionHeight)
			EyeHeight = -0.5 * CollisionHeight;
}

// Player movement.
// Player Standing, walking, running, falling.
state PlayerWalking
{
ignores SeePlayer, HearNoise;
		
	engine function AnimEnd()
	{
	local vector X,Y,Z;
	local float dir;
	local rotation ViewYaw;
	ViewYaw = Rotation;
	ViewYaw.Pitch = 0;
	GetAxes(ViewYaw,X,Y,Z);
	
	dir = Normal(Velocity) Dot X;
	if (dir > 0.9)
		{
		if (Size(Velocity) < 0.5 * GroundSpeed)
			PlayWalking();
		else
			PlayRunning();
		}
	else if (dir < -0.9)
		PlayRetreating();
	else //fixme - pick strafe direction here, since I've already got axes
		PlayStrafing(); 
	}
	
	function PlayerTick( float DeltaTime )
	{
		// Update acceleration.
		local vector X,Y,Z;
		GetAxes(Rotation,X,Y,Z);

		aForward *= 0.1;
		aStrafe  *= 0.1;
		aLookup  *= 0.3;
		aTurn    *= 0.3;

		Acceleration = aForward*X + aStrafe*Y;  
			
		// Update rotation.
		ViewRotation.Pitch += 32.0 * DeltaTime * aLookUp;
		ViewRotation.Pitch = ViewRotation.Pitch & 65535;
		If ((ViewRotation.Pitch > 18000) && (ViewRotation.Pitch < 49152))
			{
			If (aLookUp > 0) 
				ViewRotation.Pitch = 18000;
			else
				ViewRotation.Pitch = 49152;
			}
		ViewRotation.Yaw += 32.0 * DeltaTime * aTurn;
		Rotation.Yaw = ViewRotation.Yaw;
	}

Begin:
	EyeHeight = BaseEyeHeight;
	if (Physics != PHYS_Falling) Physics = PHYS_Walking;
	NextState = PlayerWalking; 
	if  (AnimRate == 0.0) PlayWalking();
	Log("player walking");
}

state PlayerFlying
{
ignores SeePlayer, HearNoise;
		
	engine function AnimEnd()
	{
	local vector X,Y,Z;
	local float dir;
	local rotation ViewYaw;
	ViewYaw = Rotation;
	ViewYaw.Pitch = 0;
	GetAxes(ViewYaw,X,Y,Z);
	
	dir = Normal(Velocity) Dot X;
	if (dir > 0.9)
		{
		if (Size(Velocity) < 0.5 * GroundSpeed)
			PlayWalking();
		else
			PlayRunning();
		}
	else if (dir < -0.9)
		PlayRetreating();
	else //fixme - pick strafe direction here, since I've already got axes
		PlayStrafing(); 
	}
	
	function PlayerTick( float DeltaTime )
	{
		// Update acceleration.
		local vector X,Y,Z;
		GetAxes(Rotation,X,Y,Z);

		aForward *= 0.1;
		aStrafe  *= 0.1;
		aLookup  *= 0.3;
		aTurn    *= 0.3;

		Acceleration = aForward*X + aStrafe*Y;  
		// Update rotation.
		ViewRotation.Pitch += 32.0 * DeltaTime * aLookUp;
		ViewRotation.Pitch = ViewRotation.Pitch & 65535;
		If ((ViewRotation.Pitch > 18000) && (ViewRotation.Pitch < 49152))
			{
			If (aLookUp > 0) 
				ViewRotation.Pitch = 18000;
			else
				ViewRotation.Pitch = 49152;
			}
		ViewRotation.Yaw += 32.0 * DeltaTime * aTurn;
		Rotation.Yaw = ViewRotation.Yaw;
	}

Begin:
	EyeHeight = BaseEyeHeight;
	Physics = PHYS_Flying;
	NextState = PlayerFlying; 
	if  (AnimRate == 0.0) PlayWalking();
	Log("player flying");
}

state CheatFlying
{
ignores SeePlayer, HearNoise;
		
	engine function AnimEnd()
	{
	local vector X,Y,Z;
	local float dir;
	local rotation ViewYaw;
	ViewYaw = Rotation;
	ViewYaw.Pitch = 0;
	GetAxes(ViewYaw,X,Y,Z);
	
	dir = Normal(Velocity) Dot X;
	if (dir > 0.9)
		{
		if (Size(Velocity) < 0.5 * GroundSpeed)
			PlayWalking();
		else
			PlayRunning();
		}
	else if (dir < -0.9)
		PlayRetreating();
	else //fixme - pick strafe direction here, since I've already got axes
		PlayStrafing(); 
	}
	
	function PlayerTick( float DeltaTime )
	{
		// Update acceleration.
		local vector X,Y,Z;
		GetAxes(ViewRotation,X,Y,Z);

		aForward *= 0.1;
		aStrafe  *= 0.1;
		aLookup  *= 0.3;
		aTurn    *= 0.3;
		aUp		 *= 0.1;
	
		Acceleration = aForward*X + aStrafe*Y + aUp*vect(0,0,1);  
		MoveSmooth(Acceleration * DeltaTime);
		// Update rotation.
		ViewRotation.Pitch += 32.0 * DeltaTime * aLookUp;
		ViewRotation.Pitch = ViewRotation.Pitch & 65535;
		If ((ViewRotation.Pitch > 18000) && (ViewRotation.Pitch < 49152))
			{
			If (aLookUp > 0) 
				ViewRotation.Pitch = 18000;
			else
				ViewRotation.Pitch = 49152;
			}
		ViewRotation.Yaw += 32.0 * DeltaTime * aTurn;
		Rotation.Yaw = ViewRotation.Yaw;
	}

Begin:
	EyeHeight = BaseEyeHeight;
	Physics = PHYS_None;
	NextState = CheatFlying; 
	if  (AnimRate == 0.0) PlayWalking();
	Log("cheat flying");
}

//===============================================================================
// Common states for players and monsters (dying and death)
		
state Dying
{
ignores SeePlayer, HearNoise, Die;

engine function Damage( int Damage, Actor instigatedBy, Vector hitlocation, 
						Vector momentum)
	{
	Velocity += momentum/Mass;
	Physics = PHYS_Falling;  
	}

engine function Landed()
	{
		Physics = PHYS_None;
		log(class$" Landed while dying");
	}

Begin:
	Log(class$" dying");
	Physics = PHYS_Falling;
	if (bIsPlayer) //play death scene in third person 
		bBehindView = true;
	NextState = 'Dead';
	if (Owner != None)
		Owner.Trigger(Self);
	Disable('ServerJump');
	Disable('ServerFire');
	PlayDying();
	FinishAnim();
	GotoState(Dead);
}

state Dead
{
ignores Die, SeePlayer, HearNoise;

engine function Damage( int Damage, Actor instigatedBy, Vector hitlocation, 
						Vector momentum)
	{
	Velocity += momentum/Mass;   
	Physics = PHYS_Falling;  

	}

function Callback(object Other)
	{
		Target = Actor(Other);
	}
	
engine function Landed()
	{
		Physics = PHYS_None;
		log(class$" Landed while dead");
	}

function ReStartPlayer()
{
	Broadcast(NoName,PlayerStart).Callme(Self);
	SetLocation(Target.Location);
	Velocity = vect(0,0,0);
	Acceleration = vect(0,0,0);
	Rotation = rot(0,0,0);
	Health = 100;
	bBehindView = false;
	SetCollision(true, true , true);
	GotoState(PlayerWalking);
	//FIXME - should set rotation based on playerstart
}

engine function ServerJump( float F, name N, string[255] S )
	{
	if (bIsPlayer)
		ReStartPlayer();
	}

engine function Timer( int TimerTicks )
	{
	if (bIsPlayer)
		ReStartPlayer();
	else
		{
		Destroy();
		}	
	}

Begin:
	Log(class$" died");
	SetTimer(30.0,false); //remove creature or respawn player after 30 seconds
	SetCollision(false, false, false);
}

//**********************************************************************************
//Base Monster AI

//Waiting:  default state for monsters
//FIXME - need SeeMonster for other creatures
auto state Waiting
{	
engine function AnimEnd()
	{
	Disable('AnimEnd');
	if (NextState == 'Acquisition')
		{
		playAnim(SeqWaitingToFighter,0.2); //FIXME - speed based on skill
		GotoState(Acquisition);
		}
	else if (NextState == 'WaitingGuard')
		PlayWaitingGuard();
	else if (NextState == 'WaitingAmbush')
		PlayWaitingAmbush();
	else if(NextState == 'Waiting')
		PlayWaiting();
	}
 
engine function Landed()
	{
		Physics = PHYS_None;
		log(class$" Landed");
	}


Begin:
		Physics = PHYS_Falling; //make sure on ground
		if (bIsPlayer) 
			GotoState(PlayerWalking);  
		if (Orders != NoName)
			GotoState(Orders);
		NextState = Waiting;
		NextAnim = NoName;
		Alertness = 0.0;
		bReadyToAttack = false;
		Log(class$" Waiting");

AllWaiting:	
		Enemy = None; 
		Rotation.Pitch = 0;
		Rotation.Roll = 0;
		if (Physics != PHYS_Falling) Physics = PHYS_None;
		if (AnimRate == 0.0) PlayWaiting();
}



state Roaming
{
engine function AnimEnd()
	{
	Disable('AnimEnd');
	if (NextState == 'Acquisition')
		{
		playAnim(SeqWaitingToFighter,0.2);
		GotoState(Acquisition);
		}
	else if (NextState == 'Roaming')
		PlayWalking();
	}

/* PickedDestination()
*/
function vector PickedDestination()
	{
	local vector pick;
	//FIXME - pick pathnode locations (make sure there is a routed path to them)
	
	pick = 500 * VRand();
	//pick = Location + Reachable(pick) * (pick - Location);
	pick.Z = FloorZ(pick);
	if (Size(pick - Location) < 2 * CollisionRadius)
		pick = Location + CollisionRadius * vector(Rotation);	
	return pick;
	}

Begin:
	NextState = Roaming; 
	Alertness = 0.0;
	bReadyToAttack = false;
	Log(class$" Roaming");

Roam: //FIXME -add stasis mode? - also set random start point in roam area
	//FIXME - use routing to make roam successful
	//FIXME - walk (1/3 speed), don't run
	if (AnimRate == 0.0) PlayWalking();
	MoveTo(PickedDestination());
	Goto(Roam);
}

state Patroling
{
function GoAcquire()
	{
		playAnim(SeqWaitingToFighter,0.2);
		GotoState(Acquisition);
	}
engine function AnimEnd()
	{
	Disable('AnimEnd');
	if (NextState == 'Acquisition')
		GoAcquire();
	else if (NextState == 'Patroling')
		PlayWalking();
	else if (NextState == 'PatrolTurn')
		PlayTurning();
	else if (NextState == 'PatrolLook')
		{
		Enable('AnimEnd');
		PlayPatrolStop();
		}
	
	}

Begin:
	NextState = Patroling; 
	Alertness = 0.0;
	bReadyToAttack = false;
	Log(class$" Patroling");
	
		

Patrol: //FIXME -add stasis mode? - also set random start point in roam area
	//FIXME - make patrol a special case of roam?
	//FIXME - use routing to make roam successful
	//FIXME - walk (1/3 speed), don't run
	Broadcast(NoName, Patrolpoint).TellAboutTo(Self);
	if (OrderObject != None)
		{
		log("Move to next patrol point");
		if (AnimRate == 0.0) PlayWalking();
		else
			{
			NextState = Patroling;
			Enable('AnimEnd');
			}
		MoveTo(OrderObject.Location);
		if (Patrolpoint(OrderObject) != None)
			{
			OrderTag = (Patrolpoint(OrderObject)).Nextpatrol;
			if ((Patrolpoint(OrderObject)).pausetime > 0.0)
				{
				Enable('AnimEnd');
				NextState = PatrolTurn;
				TurnTo(Location + (Patrolpoint(OrderObject)).lookdir);
				Enable('AnimEnd');
				NextState = PatrolLook;
				log("stop here for "$(Patrolpoint(OrderObject)).pausetime);
				Sleep((Patrolpoint(OrderObject)).pausetime);
				PlayWalking(); //FIXME play interpolated transition
				}
			Goto(Patrol);
			}
		}
	else
		{
		NextState = PatrolLook;
		if (AnimRate == 0.0) PlayPatrolStop();
		Enable('AnimEnd');
		}
	}

state Guarding
{
engine function AnimEnd()
	{
	Disable('AnimEnd');
	if (NextState == 'Acquisition')
		{
		playAnim(SeqWaitingToFighter,0.2);
		GotoState(Acquisition);
		}
	else if (NextState == 'MovingGuard')
		PlayWalking();
	else if (NextState == 'TurningGuard')
		PlayTurning();
	else if(NextState == 'Guarding')
		{
		Log("bad nextstate for guarding animend");
		PlayFighter();
		}
	}

ResumeGuarding: //get back in position to guard OrderObject
	
	if (LineOfSightTo(OrderObject))
		if (size(Location - OrderObject.Location) < CollisionRadius + OrderObject.CollisionRadius + 200)
			Goto('Turn');

	NextState = MovingGuard;
	PlayAnim(SeqFighterToMoving);			
	MoveTo(0.5 * (Location + OrderObject.Location));
	Goto(ResumeGuarding);
	
Turn:
	if (bool(Enemy))
		{
		NextState = TurningGuard;
		TurnTo(LastSeenPos);
		}
Begin:
	NextState = WaitingGuard; 
	Alertness = 0.0;
	bReadyToAttack = false;
	Log(class$" Guarding"$OrderObject.class);
	GotoState(Waiting, 'AllWaiting'); 
}

state Ambushing
{
engine function AnimEnd()
	{
	local Ambushpoint oldspot;
	Disable('AnimEnd');
	if (NextState == 'Ambushing')
		{
		playFighter();
		}
	else if (NextState == 'AmbushMove')
		PlayWalking();
	else if (NextState == 'AmbushTurn')
		PlayTurning();
	else if(NextState == 'Acquisition')
		{
		oldspot = Ambushpoint(OrderObject);
		if (oldspot != None)
			oldspot.taken = false;
		playAnim(SeqWaitingToFighter,0.2);
		GotoState(Attacking);
		}
	}

FindAmbushSpot:
	OrderObject = None; //clear old ambush point
	if ((Enemy == None) || (FRand() < 0.7))
		Broadcast(NoName, Ambushpoint).TellAboutTo(Self);

Begin:
	
	if (OrderObject != None)
		{
		Physics = PHYS_Walking;
		NextState = AmbushMove;
		Enable('AnimEnd');
		MoveTo(OrderObject.Location);
		NextState = AmbushTurn;
		Enable('AnimEnd');	
		TurnTo(Location + (Ambushpoint(OrderObject)).lookdir);
		Enemy = None; 
		}
	else if (Enemy != None)
		{
		Physics = PHYS_Walking;
		NextState = AmbushTurn;
		Enable('AnimEnd');
		TurnTo(0.5 * (Enemy.Location + LastSeenPos));
		Enemy = None; 
		}
	
	NextState = WaitingAmbush;
	Alertness = 1.0;
	bReadyToAttack = true;
	Log(class$" waiting in ambush");
	GotoState(Waiting, 'AllWaiting'); 
}
	
/* Acquisition - 
Creature has just reacted to stimulus, and set an enemy
- depending on strength of stimulus, and ongoing stimulii, vary time to focus on target and start attacking (or whatever.  FIXME - need some acquisition specific animation
HearNoise and SeePlayer used to improve/change stimulus
*/

state Acquisition
{
engine function HearNoise(float Loudness, Actor NoiseMaker)
{
	local float OldStimulus;
	local Vector HearingError;

	OldStimulus = Stimulus;
	if(NoisePerceived(NoiseMaker,Loudness))
		{
		HearingError = Max(500 - Stimulus, 0.0) * VRand();
		HearingError.Z = 0.0;
		if (Stimulus > OldStimulus)
			{
			if (Pawn(NoiseMaker) != None)
				{ 
				if (SetEnemy(Pawn(NoiseMaker)))
					LastSeenPos = NoiseMaker.Location + HearingError;
				}				
			else if (NoiseMaker.instigator != None)
				{
				if (SetEnemy(NoiseMaker.instigator))
					LastSeenPos = NoiseMaker.Location + HearingError;
				}				
			} 
		else  Stimulus = OldStimulus;			
	}
}

engine function SeePlayer(Actor SeenPlayer)
{
	local float OldStimulus;

	OldStimulus = Stimulus;
		
	if (Pawn(SeenPlayer).Health > 0)
		{  
		InFieldOfView(SeenPlayer);
		if (Stimulus > 0.0)
			{
			if (Stimulus > OldStimulus)
				{
				if (SetEnemy(Pawn(SeenPlayer)))
					LastSeenPos = SeenPlayer.Location;
				}
			}
		else
			Stimulus = OldStimulus;
		}
	SightCounter = SightCounter + 0.2; //longer interval when acquiring
		
} 

engine function AnimEnd()
{
	if (NextState == 'Attacking')
		{
		PlayFighter();
		GotoState(Attacking, SetAttackTimer);
		}
	else if (NextState == 'Ambushing')
		{
		PlayFighter();
		GotoState(Ambushing);
		}
	else
		{
		PlayTurning(); 
		Disable('AnimEnd');
		}
}

Begin:
	Alertness = -1.0; //acquire only when extremely visible
	Log("Acquiring enemy");
	Physics = PHYS_Walking;
	Log("Enemy position = "$Enemy.Location);
	Log("Last seen position = "$LastSeenPos);
	TurnTo(LastSeenPos); 
	Sleep(0.5); //FIXME - base on difficulty
	Log("Focus = "$Focus);
	Log("Stimulus = "$Stimulus);
	if (LineOfSightTo(Enemy))
		{
		InFieldOfView(Enemy); 
		LastSeenPos = Enemy.Location; 
		If (stimulus <= 0.0)
			{
			LastSeenPos.X = LastSeenPos.X + 200 * FRand();
			LastSeenPos.Y = LastSeenPos.Y + 200 * FRand();
			Goto(Begin);
			}
		else
			{
			Log("Enemy Acquired!");
			NextState = Attacking;
			Enable('AnimEnd');
			}
		}
	else
		{
		if (AttitudeTo(Enemy) == ATTITUDE_Fear)  //will run away from noise
			{
			Log("Run away from noise");
			NextState = Attacking;
			Enable('AnimEnd');
			}
		else if (BaseAggressiveness + Aggressiveness < 0.0)
			{
			Log("try to ambush noisemaker");
			TurnTo(0.5 * (Enemy.Location + LastSeenPos));
			NextState = Ambushing;
			Enable('AnimEnd');
			}
		else if ((Intelligence > BRAINS_Reptile) && (FRand() > 0.5)) 
			{ //smart, aggressive creatures may ambush or investigate
			Log("ambush noisemaker");
			TurnTo(0.5 * (Enemy.Location + LastSeenPos));
			NextState = Ambushing;
			Enable('AnimEnd');
			}
		else //investigate noise
			{
			Log("investigate noise");
			MoveTo(LastSeenPos);
			LastSeenPos = Enemy.Location;
			Goto(Begin);
			}
		}
}

/* Attacking
Master attacking state - choose which type of attack to do from here
*/
state Attacking
{
ignores SeePlayer, HearNoise;

function ChooseAttackMode()
	{
	local bool bFoundState;
	local eAttitude AttitudeToEnemy;
	local float Aggression;
	bFoundState = false;
	AttitudeToEnemy = AttitudeTo(Enemy);

	//play transition from base attack position to appropriate for chosen attack state
	if (Enemy.Health <= 0)
		{
		bFoundState = true;
		if (bool(OldEnemy)) 
			{
			Enemy = OldEnemy;
			OldEnemy = None;
			PlayAnim(SeqFighterToMoving);
			NextState = Hunting;
			GotoState(Hunting);
			}
		else
			{
			NextState = VictoryDance;
			GotoState(VictoryDance);
			}
		}
		
		
	else if (AttitudeToEnemy == ATTITUDE_Fear)
		{
		bFoundState = true;
		PlayAnim(SeqFighterToMoving);
		NextState = Retreating;
		GotoState(Retreating);
		}

	else if (AttitudeToEnemy == ATTITUDE_Threaten)
		{
		bFoundState = true;
		PlayFighter();
		NextState = Threatening;
		GotoState(Threatening);
		}

	//FIXME - can I get enemy not visible info from engine function? not guaranteed?
	else if (!LineOfSightTo(Enemy))
		{
		bFoundState = true;
		if (Orders == 'Guarding')
			{
			PlayFighter();
			GotoState(Guarding, 'ResumeGuarding');
			}
		else if (Aggressiveness + BaseAggressiveness > FRand() - 1.0)
			{ //hunt, or if smart, decide if to ambush - FIXME also base on skill
			if ((Intelligence > BRAINS_REPTILE) &&
				(RelativeStrength(Enemy) 
					> Aggressiveness + BaseAggressiveness - FRand() + 1.0))
				{
				PlayFighter();
				NextState = Ambushing;
				GotoState(Ambushing, 'FindAmbushSpot');
				}
			else
				{
				PlayAnim(SeqFighterToMoving);
				NextState = Hunting;
				GotoState(Hunting);
				}
			}
		else
			{
			PlayFighter();
			NextState = Ambushing;
			GotoState(Ambushing, 'FindAmbushSpot');
			}	
		}	
	
	else if (bReadyToAttack)
		{
		bFoundState = true;
		bReadyToAttack = false;
		Log("Attack!");
		Target = Enemy;
		If (Size(Enemy.Location - Location) <= (MeleeRange + Enemy.CollisionRadius + 			CollisionRadius))
			{
			NextState = MeleeAttack;
			GotoState(MeleeAttack);
			}
		else if (bHasRangedAttack)
			{
			NextState = RangedAttack;
			GotoState(RangedAttack);
			}
		else
			{
			log("can't attack");
			bReadyToAttack = true;
			bFoundState = false;
			}
		}
		
	if (!bFoundState) //decide whether to snipe, charge, or make a tactical move
		{
		Aggression = Aggressiveness + BaseAggressiveness + 2 * FRand() - 1.0;
		if (!bHasRangedAttack) 
			Aggression = 2.0;
		else if (Location.Z > Enemy.Location.Z + 160) //tactical height advantage
			Aggression -= 1.0;
		//FIXME - also base decision on enemy weapon, if human intelligence
		//FIXME - also check if enemy is retreating
		if (Aggression < 0.5) //Snipe or Tactical move, depending on skill level
			{ 
			if (Frand() < 0.3) //FIXME- should be based on skill level (higher skills move more)
				{
				NextState = Sniping;
				PlayAnim(SeqFighterToMoving);
				GotoState(Sniping);
				}
			else
				{
				NextState = TacticalMove;
				PlayAnim(SeqFighterToMoving);
				GotoState(TacticalMove);
				}
			}
		else //charge!
			{
			NextState = Charging;
			PlayAnim(SeqFighterToMoving);
			GotoState(Charging);
			}
		}
	Log("Next state is "$NextState);
	}

engine function AnimEnd()
	{
	ChooseAttackMode();
	}

//EnemyNotVisible implemented so engine will update LastSeenPos
function EnemyNotVisible()
	{
	Log("enemy not visible");
	}

engine function Timer( int TimerTicks )
	{
	bReadyToAttack = True;
	}

SetAttackTimer:
	Log(class$" set attack timer");
	SetTimer(TimeBetweenAttacks  * (1.0 + FRand()),false); //FIXME vary based on skill level
	
Begin:
	if (TimerCounter >= TimerRate) Log("attack timer not reset");
	Log(class$" Attacking");
	if (Physics != PHYS_Falling) Physics = PHYS_Walking;
	Acceleration = vect(0,0,0);
	if (AnimRate == 0.0) ChooseAttackMode();
	TurnToward(Enemy);
}

state Threatening
{
//ignores SeePlayer if enemy is a player //but not hear noise
engine function AnimEnd() 
	{
	if (AttitudeTo(Enemy) != ATTITUDE_Threaten)
		{
		PlayFighter();
		GotoState(Attacking, SetAttackTimer);
		}
	else if (NextState == 'Ambushing')
		{
		PlayFighter();
		GotoState(Ambushing);
		}
	else if (NextState == 'Threatening')
		PlayThreatening();
	else if (NextState == 'ThreatenAdvance')
		PlayWalking();
	}

function EnemyNotVisible()
	{
	Log("enemy not visible");
	NextState = 'Ambushing';
	Enable('AnimEnd'); 
	}


Begin:
	if (Enemy.bIsPlayer)
		Disable('SeePlayer'); //but not hear noise
	//FIXME - if guarding, get mad if enemy gets too close to order object
	//also, if guarding, stay between guard object and enemy
	TurnToward(Enemy);
	Sleep(1.0);
	if (Orders == 'Guarding')
		{ //stay between enemy and guard object
		If (Enemy.bIsPlayer &&
			(Size(Enemy.Location - OrderObject.Location) < OrderObject.CollisionRadius + 3 * CollisionRadius + MeleeRange))
				{
				AttitudeToPlayer = ATTITUDE_Hate;
				Goto(Begin);
				}
		}
	else if (FRand() < 1.4 - Aggressiveness - BaseAggressiveness) //mostly just turn
		Goto(Begin);
	else if (Size(Enemy.Location - Location) < 2.5 * (CollisionRadius + Enemy.CollisionRadius + MeleeRange))
		Goto(Begin);
	Disable('AnimEnd');
	FinishAnim();
	NextState = ThreatenAdvance;
	PlayAnim(SeqFighterToMoving); 
	FinishAnim();
	NextState = ThreatenAdvance;
	PlayWalking();
	Enable('AnimEnd');
	if (Orders == 'Guarding') //stay between enemy and guard object
		MoveTo(OrderObject.Location + (OrderObject.CollisionRadius + 2.5 * CollisionRadius) * Normal(Enemy.Location - OrderObject.Location));
	else
		MoveTo(Location + 0.5 * (Enemy.Location - Location));
	Disable('AnimEnd');
	FinishAnim();
	if (AttitudeTo(Enemy) != ATTITUDE_Threaten)
		{
		PlayFighter();
		GotoState(Attacking, SetAttackTimer);
		}
	else
		{
		PlayAnim(SeqMovingToFighter);
		NextState = Threatening;
		Enable('AnimEnd');
		Goto(Begin);
		}
}

state Retreating
{
ignores SeePlayer, HearNoise;

engine function Damage( int Damage, Actor instigatedBy, Vector hitlocation, 
						Vector momentum)
{
	CallGlobal.Damage(Damage, instigatedBy, hitlocation, momentum);
	if (NextAnim == 'TakeHit')
		GotoState(Attacking, SetAttackTimer); //re-assess what to do
}

engine function AnimEnd() 
	{
	if (NextState == 'Retreating')
		{
		PlayRunning();
		Disable('AnimEnd');
		} 
	else if (NextState == 'Attacking')
		{
		PlayAnim(SeqMovingToFighter);
		GotoState(Attacking, 'SetAttackTimer'); //FIXME - use timer here
		}
	}

function vector PickedDestination()
	{
	local vector pick;
	
	pick = 200 * Frand() * VRand() + 300 * FRand() * Normal(Location - Enemy.Location);
	pick.Z = FloorZ(pick);
	//pick = Location + Reachable(pick) * (pick - Location);
	if (Size(pick - Location) < 2 * CollisionRadius)
		pick = Location + CollisionRadius * vector(Rotation);	
	return pick;
	}

Begin:
	//FIXME - use routing -retreat to base
	//then stop being afraid - also heal slowly at base
	//FIXME - have higher skill/IQ creatures strafe backwards, while firing
	MoveTo(PickedDestination()); 
	Goto(Begin);
}

state Charging
{
ignores SeePlayer, HearNoise;

engine function HitWall(vector HitNormal)
{
	local float reachdist;
	local vector hitleft, HitLocation, TraceNormal, AlongWall;
	local actor HitActor;
	
	//reachdist = Reachable(Enemy.Location);
	log("Charging "$class$" hit wall");
	if (reachdist < 1.0)
	{
		log("try to slide off corner");
		//FIXME - use navigation when available
		//FIXME - give up charge if not possible to reach
		//FIXME - should global HitWall do this?
		//FIXME - flying/swimming creatures will need up/down attempt too
		AlongWall.X = HitNormal.Y;
		AlongWall.Y = -1 * HitNormal.X;
		AlongWall.Z = 0;
		
		HitActor = Trace(HitLocation, TraceNormal, 
		 		(Location + AlongWall * CollisionRadius) , Enemy.Location, true);
		hitleft = HitLocation;
		HitActor = Trace(HitLocation, TraceNormal, 
		 		(Location - AlongWall * CollisionRadius) , Enemy.Location, true);
		 		
		if (size(hitleft - Location) > size(HitLocation - Location))
			LastSeenPos = Location + AlongWall * CollisionRadius; //go left
		else
			LastSeenPos = Location - AlongWall * CollisionRadius; //go right
		
		GotoState(Charging, 'StepOut');
	}
}
					
engine function Damage( int Damage, Actor instigatedBy, Vector hitlocation, 
						Vector momentum)
{
	CallGlobal.Damage(Damage, instigatedBy, hitlocation, momentum);
	if (NextAnim == 'TakeHit')
		GotoState(Attacking); //re-assess what to do
}

engine function AnimEnd() 
	{
	if (NextState == 'ChargeTurning')
		{
		PlayTurning();
		Disable('AnimEnd');
		}
	else if (NextState == 'Charging')
		{
		PlayRunning();
		Disable('AnimEnd');
		}
	else if (NextState == 'MovingAttack')
		{
		PlayMovingAttack();
		}
	else if (NextState == 'Attacking')
		{
		PlayAnim(SeqMovingToFighter);
		GotoState(Attacking);
		}
	}

engine function Timer( int TimerTicks )
	{
	bReadyToAttack = True;

	if (Size(Enemy.Location - Location) 
			<= (MeleeRange + Enemy.CollisionRadius + CollisionRadius))
		{ 
		NextState = Attacking;
		Enable('AnimEnd');
		}

	if (bMovingRangedAttack && (FRand() < 0.7)) //FIXME - make decision skill based
		{
		NextState = MovingAttack;
		NextAnim = NoName; //reset, so moving attack can use it
		Enable('AnimEnd');
		}
	else if (bHasRangedAttack)
		{ 
		if (Aggressiveness + BaseAggressiveness > 3 * FRand()) //then keep charging
			SetTimer(1.5,false); 
		else
			{
			NextState = Attacking;
			Enable('AnimEnd');
			}
		}
	}

function EnemyNotVisible()
	{
	Log("enemy not visible");
	NextState = 'Hunting';
	GotoState(Hunting); //no animation transition needed
	}

StepOut:
	Sleep(0.05);
	Disable('HitWall');
	StrafeFacing(LastSeenPos, Enemy); //don't change anim (short move)
	Enable('HitWall');
	Goto('CloseIn');
		
Begin:

	Log(class$ " charging");
	if (AnimRate == 0.0) PlayRunning();

Charge:
	NextState = 'ChargeTurning';
	TurnToward(Enemy);
	NextState = 'Charging';
	Enable('AnimEnd');
	
CloseIn:
	MoveToward(Enemy);
	Log("Got to enemy");
	if (bReadyToAttack) 
		{
		NextState = Attacking;
		Enable('AnimEnd');
		MoveToward(Enemy);
		}		
	else Goto(Charge);
}

state TacticalMove
{
ignores SeePlayer, HearNoise;

engine function Damage( int Damage, Actor instigatedBy, Vector hitlocation, 
						Vector momentum)
{
	CallGlobal.Damage(Damage, instigatedBy, hitlocation, momentum);
	if (NextAnim == 'TakeHit')
		GotoState(Attacking); //re-assess what to do
}

engine function AnimEnd() 
	{
	local float dir;
	
	if (NextState == 'TacticalStrafeMove')
	{
		dir = Normal(Destination - Location) Dot Normal(Enemy.Location - Location);
		if (dir > 0.9)
			PlayRunning();
		else if (dir < -0.9)
			PlayRetreating();
		else 
			PlayStrafing(); 
	}
 	else if (NextState == 'TacticalMove')
 		PlayRunning();
	else if (NextState == 'Attacking')
		{
		PlayAnim(SeqMovingToFighter);
		GotoState(Attacking);
		}
	}

engine function Timer( int TimerTicks )
	{
	bReadyToAttack = True;
//	if (bStrafingRangedAttack && (NextState == 'TacticalStrafeMove') && (FRand() < 0.75)) //FIXME - make decision skill based
//		{
//		NextState = MovingAttack;
//		NextAnim = NoName; //reset, so moving attack can use it
//		Enable('AnimEnd');
//		}
// else
	if (bHasRangedAttack || (Size(Enemy.Location - Location) 
			<= (MeleeRange + Enemy.CollisionRadius + CollisionRadius)))
		{ 
		NextState = Attacking;
		Enable('AnimEnd');
		}
	}

function EnemyNotVisible()
	{
	Log("enemy not visible");
	NextState = 'Attacking';
	Enable('AnimEnd');
	}

/* PickedDestination()
Choose a destination for the tactical move, based on aggressiveness and the tactical
situation. Make sure destination is reachable
FIXME - if enemy reachable, don't jump down to non-reachable location 
maybe never jump down below enemy unless he's reachable from destination
*/
function vector PickedDestination()
	{
	local vector pick;
	local float aggression;
	
	aggression = Aggressiveness + BaseAggressiveness + 2.0 * FRand() - 1.0;
	pick = 300 * Frand() * VRand() + 100 * FRand() * aggression * Normal(Enemy.Location - Location);
	pick.Z = FloorZ(pick);
	log("started with pick "$pick);
	//pick = Location + Reachable(pick) * (pick - Location);
	log("adjusted to pick "$pick);
	if (Size(pick - Location) < 2 * CollisionRadius)
		pick = Location + CollisionRadius * vector(Rotation);	
	return pick;
	}

Begin:

	Log(class$ " moving tactically");
	if (!bCanStrafe || (Frand() > 0.75)) //FIXME - make skill based (and also based on angle of move)
		MoveTo(PickedDestination());
	else
		{
		NextState = TacticalStrafeMove;
		StrafeFacing(PickedDestination(), Enemy);	
		}
	
	if (FRand() < 0.9) 
		{
		Log(class$ "done with move");
		NextState = Attacking;
		Enable('AnimEnd');
		MoveToward(Enemy); 
		//FIXME - instead, play transition to fighter (slowly), from whatever
		//frame I am at currently, and go to attacking immediately
		// - use the interpolation capability
		}
	else // possibility of multiple combined tacticalmoves (w/ no return to Attacking)
		Goto(Begin);
}

state Sniping
{
ignores SeePlayer, HearNoise;

engine function Damage( int Damage, Actor instigatedBy, Vector hitlocation, 
						Vector momentum)
{
	CallGlobal.Damage(Damage, instigatedBy, hitlocation, momentum);
	GotoState(Attacking); //re-assess what to do
}

engine function AnimEnd() 
	{
	if (NextState == 'Sniping')
		{
		PlayTurning();
		Disable('AnimEnd');
		}
	else if (NextState == 'Attacking')
		{
		PlayAnim(SeqMovingToFighter);
		GotoState(Attacking);
		}
	}

engine function Timer( int TimerTicks )
	{
	log("Attack timer sprung in Sniping");
	bReadyToAttack = True;
	NextState = Attacking;
	Enable('AnimEnd');
	}

function EnemyNotVisible()
	{
	Log("enemy not visible");
	NextState = 'Attacking';
	Enable('AnimEnd');
	}
	
Begin:

	Log(class$ " sniping");
	if (AnimRate == 0.0) PlayTurning();

Snipe:
	Acceleration = vect(0,0,0);
	TurnToward(Enemy);
	if (bReadyToAttack) 
		{
		NextState = Attacking;
		Enable('AnimEnd');
		}		
	Goto(Snipe);
}

state Hunting
{
engine function Damage( int Damage, Actor instigatedBy, Vector hitlocation, 
						Vector momentum)
{
	CallGlobal.Damage(Damage, instigatedBy, hitlocation, momentum);
	if (NextAnim == 'TakeHit')
		GotoState(Attacking); //re-assess what to do
}

engine function AnimEnd() 
{
	if (NextState == 'Hunting')
		{
		PlayRunning();
		Disable('AnimEnd');
		}
	else if (NextState == 'Attacking')
	{ //play transition to next state
		playAnim(SeqMovingToFighter);
		GotoState(Attacking);
	}
}

function bool SetEnemy(Pawn NewEnemy)
{
	local bool result;
	result = false;
	if (CallGlobal.SetEnemy(NewEnemy))
		{
		result = true;
		if ((!bReadyToAttack) || (!bHasRangedAttack))
			GotoState(Charging); // no animation transition needed
		else
			{
			NextState = Attacking;
			Disable('SeePlayer');
			Disable('HearNoise');
			Enable('AnimEnd');
			}
		}
	return result;
} 

engine function Timer( int TimerTicks )
{
	bReadyToAttack = true;
}


Begin:
	Log(class$" Hunting"); //FIXME put a moveto here, with a seeplayer engine function above
	//FIXME - marker for debugging
	Alertness = 0.5;
	//Spawn(StingerProjectile ,NoName,
	//		LastSeenPos,Rotation(Enemy.Location - LastSeenPos));
	if (AnimRate == 0.0) PlayRunning();

Follow:
	MoveTo(LastSeenPos); //first time, its the actual last seen position
	If (NextState != 'Attacking') //I haven't seen him
		{
		LastSeenPos = Enemy.Location; //best hope for following (without routing)
		Goto(Follow);
		}

PreAttack:
		Log("Coming out of hunting in pre-attack mode");
		MoveToward(Enemy);
		Goto(PreAttack);
	
}

//MeleeAttack and RangedAttack are implemented in the subclasses
// Except that DamageTarget is inherited by all

state MeleeAttack
{
ignores SeePlayer, HearNoise;
/* DamageTarget
check if attack hit target, and if so damage it
*/

function DamageTarget(int hitdamage)
{
	local vector TargetDir;
	local float TargetDist;
	TargetDir = Normal(Target.Location - Location);
	TargetDist = Size(Target.Location - Location);
	log("Melee damage by "$class$" to "$Target.class);
	If (TargetDist <= (MeleeRange + Target.CollisionRadius + CollisionRadius)) //still in melee range
		{
		log("Its close enough");
		If (vector(Rotation) Dot TargetDir < 0.9)	
		//FIXME - also do trace 
			Target.Damage(hitdamage, Self,Target.Location,
				(1000.0 * float(hitdamage) * 0.5 * (TargetDir + vect(0,0,1))));
		}
}

function EnemyNotVisible()
	{
	Log("enemy not visible");
	GotoState(Attacking, SetAttackTimer);
	}
	
Begin:
	Log(class$" has no Melee Attack");
	GotoState(RangedAttack);
}

state RangedAttack
{
ignores SeePlayer, HearNoise;
/* RayDamageTarget
check if ray (instant) attack hit target, and if so damage it
If ranged attack uses projectile, its impact will trigger the damage
*/
function RayDamageTarget(int hitdamage, vector RayDir)
{
	local actor HitActor;
	local vector HitLocation, HitNormal, TargetPoint;
	
	TargetPoint = Location + RayDir * Max(2000, Size(Target.Location - Location));
	
	HitActor = Trace(HitLocation, HitNormal, Location, Target.Location, true);
	if( HitActor!=None && HitActor!=Level )
		 {
	 		Log("Ray from "$class$" hit "$target.class);
	 		Target.Damage(hitdamage, Self,Target.Location,
				(1000.0 * float(hitdamage) * (Normal(Target.Location - Location) + vect(0,0,1))));
		}
}

function EnemyNotVisible()
	{
	Log("enemy not visible");
	}

Begin:
	Log(class$" has no Ranged Attack");
	GotoState(Attacking);
}

state VictoryDance
{
ignores SeePlayer, HearNoise;

Begin:
	Log(class$" Victory dance");
	Rotation.Pitch = 0;
	Rotation.Roll = 0;

	FinishAnim();
	PlayVictoryDance();
	GotoState(Waiting); //fixme - should be auto
}
