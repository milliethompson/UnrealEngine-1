      bBlockActors=True
      bBlockPlayers=True
      bProjTarget=True
      SoundVolume=0
      bMomentum=True
      bPitch=True
      bYaw=True
      bRoll=True
      bEnginePhysics=True
      bIsKillGoal=True
   End DefaultProperties
End Class

