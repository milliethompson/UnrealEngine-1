Begin Class Name=Satellite
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' A special kind of light which appears in the backdrops
' and rises/falls according to the level's day/night cycle.
'
Class Satellite Expands Light Intrinsic

Dim Period as Editable Real ' Amount that level's day cycle is scaled by, normally 1.0
Dim Phase  as Editable Real ' Phase offset from start of level time, 0.0 to 1.0
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=Sattelite
	  LightType=1
	  LightEffect=15
	  Period=1.0
	  Phase=0.0
	  bStatic=0
	  bDirectional=1
	  bOnHorizon=1
   End DefaultProperties
End Class

Begin Class Name=TorchFlame
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Class TorchFlame Expands Light Intrinsic
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=TorchFlame
      bStatic=False
      bHidden=False
      MeshMap=Flame
      DrawType=2
      DrawScale=1.0
      AnimRate=1.0
      AnimCount=0
      AnimSeq=1
      bAnimate=True
      LightType=1
	  LightEffect=2
      LightBrightness=40
      LightRadius=32
   End DefaultProperties
End Class

Begin Class Name=Spotlight
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' A directional spotlight.
'
Class Spotlight Expands Light Intrinsic
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=Spotlight
	  LightType=1
	  LightEffect=12
	  LightCone=128
	  bDirectional=1
	  bStaticActor=0
   End DefaultProperties
End Class
