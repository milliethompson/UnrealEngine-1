//=============================================================================
// QuadShot.
//=============================================================================
class QuadShot expands Weapon
	package(UnGame);

#call ..\Models\Quad.mac
#call ..\Models\Quadhand.mac

//=============================================================================
// Functions.

function Fire( float Value )
{
	if( AnimRate == 0 )
	{
		Spawn( TentacleProjectile );
		PlayAnim( Fire, 0.5 );
	}
}
