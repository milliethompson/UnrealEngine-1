Begin Class Name=beam
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//=============================================================================
// beam
//=============================================================================
class beam expands Projectile;

#exec MESH IMPORT MESH=beam ANIVFILE=..\MODELS\beam_a.3D DATAFILE=..\MODELS\beam_d.3D X=0 Y=0 Z=0
#alwaysexec MESH ORIGIN MESH=beam X=0 Y=700 Z=-0 YAW=64

#exec MESH SEQUENCE MESH=beam SEQ=All  STARTFRAME=0  NUMFRAMES=1
#exec MESH SEQUENCE MESH=beam SEQ=Still  STARTFRAME=0   NUMFRAMES=1


#exec TEXTURE IMPORT NAME=JRifle1 FILE=..\MODELS\Rifle.PCX FAMILY=!Skins PALETTE=JRifle1 FLAGS=2

#exec MESHMAP NEW   MESHMAP=beam MESH=beam
#alwaysexec MESHMAP SCALE MESHMAP=beam X=0.005 Y=0.02 Z=0.01

#exec MESHMAP SETTEXTURE MESHMAP=beam NUM=1 TEXTURE=JRifle1
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      DrawType=DT_Mesh
      Mesh=beam
   End DefaultProperties
End Class

