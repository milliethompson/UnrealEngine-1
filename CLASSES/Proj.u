Begin Class Name=BruteProjectile
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//=============================================================================
// BruteProjectile.
//=============================================================================
class BruteProjectile expands Projectile;

#call ..\Models\Tarydium.mac
#exec AUDIO IMPORT FILE="..\Sounds\NAILGUN.UFX" NAME="NAILGUN" FAMILY="Weapons"

/*engine function Spawned()
{
	PlaySound(sound(NailGun));
} */

auto state Flying
{
engine function Timer( int TimerTicks )
{
	GoToState(Exploding);
}

engine function Touch (Actor Other)
{
	local int hitdamage;
	log(Other.Class$" touched missile");

	if (Other != instigator)
	{
		hitdamage = 10;
		Other.Damage(hitdamage, instigator,Other.Location,
			(1500.0 * float(hitdamage) * (Normal(Other.Location - Location) + vect(0,0,1))));
		GotoState(Exploding);
	}
}

engine function HitWall (vector HitNormal)
{
	log("missile hit wall");
	GotoState(Exploding);
}

Begin:
	Physics = PHYS_Projectile;
	Acceleration = vect(0,0,0);
	Velocity = Vector(Rotation) * 700.0;
	SetTimer(7.0,false); //self destruct after 7.0 seconds
}

state Exploding
{
engine function Timer( int TimerTicks )
{
  	Destroy();
}

Begin:
	Physics = PHYS_None; 
	MakeNoise(1.0); //FIXME - set appropriate loudness
	SetTimer(0.1,false); 
 	Log("missile exploded");
}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      MaxSpeed=+01000.000000
      DrawScale=+00000.200000
   End DefaultProperties
End Class

