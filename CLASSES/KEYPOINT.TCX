'
' Keypoints.
'

DeclareClass Name=Keypoint
DeclareClass Name=PlayerStart
DeclareClass Name=Teleporter
DeclareClass Name=ZoneDescriptor
DeclareClass Name=BlockMonsters
DeclareClass Name=BlockAll
DeclareClass Name=LevelDescriptor

DeclareClass Name=Human

Begin Class Name=Keypoint
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' Base class of keypoints, actors which are invisible during play (which
' are used to mark places).
'
Class Keypoint Expands Actor Intrinsic
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=Keypoint
      CollisionRadius=+00010.000000
      CollisionHeight=+00010.000000
      bStatic=True
      bTemplateClass=False
	  DefaultEdCategory=General
   End DefaultProperties
End Class

Begin Class Name=AmbientSound
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' Sits there and plays its ambient sound.  This class is no different 
' than placing any other actor in a level and setting its ambient sound.
'
Class AmbientSound Expands Keypoint
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=AmbientSound
      bTemplateClass=False
	  DefaultEdCategory=Display
   End DefaultProperties
End Class

Begin Class Name=PlayerStart
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' Marks where player actors should be spawned when players enter a level.
'
Class PlayerStart Expands Keypoint

' Type of player to spawn.
Dim PlayerSpawnClass as Editable Class      ' Type of player to spawn.

' Players on different teams are not spawned in areas with the
' same TeamNumber unless there are more teams in the level than
' team numbers.
Dim TeamNumber       as Editable Byte       ' Team used in network play.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=PlayerStart
      Texture=s_player
      bDirectional=True
	  PlayerSpawnClass=Human
	  DefaultEdCategory=PlayerStart
   End DefaultProperties
End Class

Begin Class Name=Teleporter
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' Teleports actors either between different teleporters within a level
' or to matching teleporters on other levels.
'
Class Teleporter Expands Keypoint Intrinsic

' Teleporter URL can be one of the following forms:
'
' TeleporterName
'     Teleports to a named teleporter in this level.
'
' LevelName/TeleporterName
'     Teleports to a different level on this server.
'
' Unreal://Server.domain.com/LevelName/TeleporterName
'     Teleports to a different server on the net.
'
Dim TeleportURL as Editable String(64)   ' URL at the other end of the teleporter.

' Here is how we make sure that people teleporting have a certain
' version or level pack installed.
Dim ProductRequired  As Editable Name    ' Product that must be installed for teleporter to be entered.

' Teleporter flags.
Dim bChangesVelocity As Editable Boolean ' True if teleportation sets velocity to TargetVelocity.
Dim bChangesYaw      As Editable Boolean ' True if teleportation sets yaw to TargetYaw.
Dim bReversesX       As Editable Boolean ' True if teleportation reverses X-component of velocity.
Dim bReversesY       As Editable Boolean ' True if teleportation reverses Y-component of velocity.
Dim bReversesZ       As Editable Boolean ' True if teleportation reverses Z-component of velocity.

' Teleporter directions.
Dim TargetYaw        As Editable Integer ' If bChangesYaw, set target's yaw to this.
Dim TargetVelocity   As Editable Vector  ' If bChangesVelocity, set target's velocity to this.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=Teleporter
      Texture=s_player
      CollisionRadius=+00020.000000
      CollisionHeight=+00020.000000
      bCollideActors=True
      bChangesVelocity=False
      bChangesYaw=False
      bReversesX=False
      bReversesY=False
      bReversesZ=False
	  bDirectional=1
      TargetYaw=0
	  bHidden=1
      TargetVelocity=(X=+00000.000000,Y=+00000.000000,Z=+00000.000000)
	  DefaultEdCategory=Teleporter
   End DefaultProperties
End Class

Begin Class Name=BlockMonsters
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' Prevents monsters from passing, but allows players to cross.
'
Class BlockMonsters Expands Keypoint
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=BlockMonsters
      bCollideActors=True
      bBlocksPlayers=False
      BlockedClasses(0)=Pawn
      bBlocksActors=True
	  DefaultEdCategory=Collision
   End DefaultProperties
End Class

Begin Class Name=BlockAll
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' Blocks all actors from passing.
'
Class BlockAll Expands Keypoint
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=BlockAll
      bCollideActors=True
      bBlocksPlayers=True
      bBlocksActors=True
	  DefaultEdCategory=Collision
   End DefaultProperties
End Class

Begin Class Name=TextMessage
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' Displays a text message when triggered or touched.
'
Class TextMessage Expands Keypoint
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      bCollideActors=1
      Class=TextMessage
	  DefaultEdCategory=TextMessage
   End DefaultProperties
End Class

Begin Class Name=LevelDescriptor
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' Contains information about the current level. There should be one per 
' level and it should be actor 0. UnrealEd creates each level's 
' LevelDescriptor automatically so you should never have to place one
' manually.
'
Class LevelDescriptor Expands Keypoint
Retract All ' Hide all other editable property categories in UnrealEd

EnumDef ESkyTime = SKY_Day, SKY_Dusk, SKY_Night, SKY_Dawn, SKY_Max

' Physics
Dim LevelGravity   As Editable(Level) Vector     '' Gravity acceleration in level
Dim DayFactor      As Editable(Level) Real       '' How fast a day passes, 1.0=daily, 24.0=hourly, 0.0=never
Dim DayBase        As Editable(Level) Real       '' If DayFactor=0, hardcoded time of day for this level

' Time
Dim Time           As Real                       '' Time scaled where 1.0 = 1 day
Dim DayFraction    As Real                       '' How close the current time is to day
Dim NightFraction  As Real                       '' How close the current time is to night
Dim Ticks          As Integer                    '' Ticks passed since start of game
Dim Year           As Integer                    '' Year
Dim Month          As Integer                    '' Month
Dim Day            As Integer                    '' Day of month
Dim Hour           As Integer                    '' Hour
Dim Minute         As Integer                    '' Minute
Dim Second         As Integer                    '' Second
Dim Millisecond    As Integer                    '' Millisecond

' Text info about level
Dim LevelTitle     As Editable(Level) String(64) '' Human-readable name of zone
Dim LevelAuthor    As Editable(Level) String(64) '' Dude who built it
Dim LevelMusic     As Editable(Level) String(64) '' Currently a filename, will become a resource name
Dim LevelEnterText As Editable(Level) String(64) '' Message to tell players when they enter

' Flags affecting the level
Dim bLonePlayer    As Editable(Level) Boolean    '' No multiplayer coordination, i.e. for entranceways
Dim bMirrorSky     As Editable(Sky)   Boolean    '' Mirror sky below horizon

' Affecting textures in the level
Dim TexUPanSpeed   As Editable(Level) Real       '' Texture panning speeds
Dim TexVPanSpeed   As Editable(Level) Real 

' Affecting the sky motion
Dim SkyScale       As Editable(Sky) Real         '' Sky texture scale
Dim SkyDayBright   As Editable(Sky) Real         '' Sky brightness during the day
Dim SkyNightBright as Editable(Sky) Real         '' Sky brightness at night
Dim SkyUPanSpeed   As Editable(Sky) Real         '' Sky U panning speed
Dim SkyVPanSpeed   As Editable(Sky) Real         '' Sky V panning speed
Dim SkyWavyness    As Editable(Sky) Real         '' Magnitude of sky wavyness
Dim SkyWavySpeed   As Editable(Sky) Real         '' Speed of sky wavyness
Dim SkyFlicker     As Editable(Sky) Real         '' Flickering in sky

' Sky texture
Dim SkyTexture     As Editable(Sky) Texture      '' Sky texture
Dim SkyPalette     As Editable(Sky) Texture      '' Texture containing optional palette for sky

' Sky ambient lighting
Dim SkyFogBrightness As Editable(Sky) Byte       '' Sky fog brightness
Dim SkyFogHue		 As Editable(Sky) Byte       '' Sky fog hue
Dim SkyFogSaturation As Editable(Sky) Byte       '' Sky fog saturation

' Miscellaneous information:
Dim RandomSeed   as Editable(Advanced) Integer   ' Random seed value, or 0 for none.
Dim RandomValue  As                    Integer   ' Random value associated with this level.

' Level scoring and goals:
Dim ItemGoals    as Integer   ' Number of item goals in the level	
Dim KillGoals    as Integer   ' Number of kill goals in the level	
Dim SecretGoals  as Integer   ' Number of secret goals in the level	

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=LevelDescriptor
	  bTemplateClass=True
	  bHidden=True
	  bHiddenEd=True
	  bStatic=False
	  bNoDelete=True
	  bLonePlayer=False
	  bMirrorSky=True
	  DefaultEdCategory=LevelDescriptor
	  LevelGravity=(0,0,-3.0)
	  DayBase=0.0
	  DayFactor=1.0
	  TexUPanSpeed=1.0
	  TexVPanSpeed=1.0
	  SkyUPanSpeed=0.2
	  SkyVPanSpeed=0.2
	  SkyScale=1.0
	  SkyTexture=BlueSky
	  SkyWavyness=2.0
	  SkyWavySpeed=1.0
	  SkyDayBright=1.00
	  SkyNightBright=0.60
	  SkyFlicker=0.04
	  SkyFogSaturation=255
      DefaultEdCategory=Level
   End DefaultProperties
End Class

Begin Class Name=ZoneDescriptor
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' Built-in Unreal class for defining properties
' of zones.  If you place one ZoneDescriptor actor in a
' zone you have partioned, the ZoneDescriptor defines the 
' properties of the zone.
'
Class ZoneDescriptor Expands Keypoint
Retract All ' Hide all other editable property categories in UnrealEd.

' Zone title.
Dim ZoneName      as Editable String(32) ' Human-readable name of zone.

' Zone flags.
Dim bWaterZone    as Editable Boolean    ' Zone is water-filled.
Dim bFogZone      as Editable Boolean    ' Zone is fog-filled.
Dim bKillZone     as Editable Boolean    ' Zone instantly kills those who enter.
Dim bEchoZone     as Editable Boolean    ' Sound echoes in this zone.
Dim bNeutralZone  as Editable Boolean    ' Players can't take damage in this zone.
Dim bGravityZone  as Editable Boolean    ' Use ZoneGravity.
Dim bTeamOnly     as Editable Boolean    ' Only allows players from team name ZoneName.

' Zone movement.
Dim ZoneGravity   as Editable Vector     ' Gravity acceleration in zone, if bGravityZone
Dim ZoneVelocity  as Editable Vector     ' Velocity added to actors in this zone.

' Audio properties.
Dim ZoneAmbientSound as Editable Sound   ' Ambient music/sound to play, if any.
Dim ZoneBreadth      as Editable Real    ' Size of zone, for echo delay.
Dim ZoneReflectivity as Editable Real    ' Reflectivity of zone, for echo loudness.

' Ambient lighting parameters.
Dim AmbientBrightness as Editable Byte   ' Ambient lighting level in this zone.
Dim AmbientHue		  as Editable Byte   ' Hue of all ambient zone lighting.
Dim AmbientSaturation as Editable Byte   ' Saturation of ambient zone lighting.

' Ramp lighting parameters.
' These take effect on regular Pentiums but not MMX technology Pentiums.
Dim RampHue		      as Editable Byte   ' Hue of all lights in this zone.
Dim RampSaturation    as Editable Byte   ' Saturation of all lights in this zone.

' Zone fog parameters.
' On regular Pentiums these take effect only if bFogZone is set, and fog can't
' coexist with regular lighting. On MMX machines, these always
' take effect and they coexist with regular lighting.
Dim FogThickness      as Editable Byte
Dim FogHue		      as Editable Byte
Dim FogSaturation     as Editable Byte

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=ZoneDescriptor
	  AmbientSaturation=255
	  RampSaturation=255
	  FogSaturation=255
	  FogThickness=63
	  DefaultEdCategory=ZoneDescriptor
      bHidden=1
   End DefaultProperties
End Class
