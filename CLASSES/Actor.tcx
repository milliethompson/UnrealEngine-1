      BlockedClasses(0)=None
      BlockedClasses(1)=None
      BlockedClasses(2)=None
      PassedClasses(0)=None
      PassedClasses(1)=None
      PassedClasses(2)=None
	  DefaultEdCategory=General
   End DefaultProperties
End Class
