'
' Actor classes exported from UnrealEd.
'
DeclareClass Name=Actor

Begin Class Name=Actor
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' Actor: The root of all actor classes.
' This is a built-in Unreal class and it shouldn't be modified.
'
Class Actor Intrinsic

'
' Enumerations.
'

EnumDef EDrawType = DT_None, DT_Sprite, DT_MeshMap, DT_Brush

EnumDef EBlitType = BT_None, BT_Normal, BT_Transparent

EnumDef ELightType = LT_None, LT_Steady, LT_Pulse, LT_Blink, _
   LT_Flicker, LT_Strobe, LT_BackdropLight

EnumDef ELightEffect = LE_None, LE_TorchWaver, LE_FireWaver, _
   LE_WateryShimmer, LE_Searchlight, LE_SlowWave, LE_FastWave, _
   LE_CloudCast, LE_StaticSpot, LE_Shock, LE_Disco, LE_Warp, _
   LE_Spotlight, LE_StolenQuakeWater, LE_ChurningWater, _
   LE_Satellite, LE_Interference, LE_Cylinder, LE_Rotor, _
   LE_Unused

EnumDef ETextMsgType = LOG_None

EnumDef EClientUpdateType = UPD_None, UPD_Static, UPD_Explicit, _
   UPD_Visible, UPD_Always

'todo: This shouldn't be hardcoded.
EnumDef EAmmoType = _
    AmmoType_Bullets       _  ' Bullets                              
,   AmmoType_Shells        _  ' Shells                               
,   AmmoType_StingerAmmo   _  ' Stinger ammo
,   AmmoType_FlameGunAmmo  _  ' Ammo for flame gun
,   AmmoType_Reserved2     _  ' To be defined (change the name when defined)  
,   AmmoType_Reserved3     _  ' To be defined (change the name when defined)  
,   AmmoType_Reserved4     _  ' To be defined (change the name when defined)  
,   AmmoType_Reserved5     _  ' To be defined (change the name when defined)  
,   AmmoType_Reserved6     _  ' To be defined (change the name when defined)  
,   AmmoType_Reserved7     _  ' To be defined (change the name when defined)  
,   AmmoType_Count         _  ' Count of ammo types
,   AmmoType_None             ' No ammo.

'todo: Is this still relevant?
EnumDef EDamageType = _
    DMT_Basic         _  ' Basic physical damage (blunt force, projectile)
,   DMT_Water         _  ' Damage due to water
,   DMT_Fire          _  ' Damage due to fire
,   DMT_Electric      _  ' Damage to to electricity
,   DMT_Count         _  ' Count of different kinds of damage
,   DMT_None             ' Special value to indicate no damage

'todo: Move elsewhere?
EnumDef EAI_Task =         _ ' The main AI task is...
    EAI_TaskNone               _ ' ... to do nothing.
,   EAI_TaskMove               _ ' ... to move (towards a spot, in a direction, ...)
,   EAI_TaskSearch             _ ' ... to search the area.
,   EAI_TaskWait               _ ' ... to wait for something.
,   EAI_TaskAttack               ' ... to attack a target.

'
' Variables used by the client, server, and editor.
'

' The actor's class.
Dim Class			 As Editable(Main) Class

' The actor's position and rotation.
Dim Location		 As Editable(Main) Vector
Dim Velocity		 As Editable(Main) Vector
Dim DrawRot			 As Editable(Main) Rotation
Dim ViewRot			 As Editable(Main) Rotation

' Relations to other actors.
Dim Parent			 As Editable(Main) Actor
Dim Weapon			 As Editable(Main) Actor

' Display.
Dim DrawType		 As Editable(Display) EDrawType
Dim BlitType		 As Editable(Display) EBlitType
Dim Texture			 As Editable(Display) Texture   ' Sprite texture if DrawType=DT_Sprite.
Dim MeshMap			 As Editable(Display) MeshMap   ' Mesh if DrawType=DT_MeshMap.
Dim Brush			 As Editable(Display) ExportResource Const Model ' Brush if DrawType=DT_Brush.
Dim DrawScale		 As Editable(Display) Real      ' Scaling factor, 1.0=normal size.
Dim InherentGlow     As Editable(Display) Byte      ' Base brightness when no lights hit it.

' Ambient sound.
Dim AmbientSound	 As Editable(Display)  Sound
Dim SoundRadius		 As Editable(Display)  Byte
Dim SoundVolume      As Editable(Display)  Byte

' Animation.
Dim AnimSeq			 As Editable(Animation) Byte    ' Mesh sequence number, or non-zero value to indicate texture animation.
Dim AnimRate		 As Editable(Animation) Real    ' Added to AnimBase each tick
Dim AnimBase		 As Editable(Animation) Real    ' Integer part identifies current frame number to draw with.
Dim AnimCount		 As Editable(Animation) Byte    ' Number of times to do animation. 1=finish current, 0=do forever
Dim AnimFirst		 As Editable(Animation) Byte    ' Index (from 0) of first frame.
Dim AnimLast		 As Editable(Animation) Byte    ' Index (from 0) of last frame.
Dim AnimMessage      As Integer ' Parameterless message sent at end of animation.

' Collision.
Dim CollisionRadius  As Editable(Collision) Real    ' Radius of collision sphere.
Dim CollisionHeight  As Editable(Collision) Real    ' Height of sphere center off ground.

' Lighting.
Dim LightType		 As Editable(Lighting) ELightType
Dim LightEffect		 As Editable(Lighting) ELightEffect
Dim LightBrightness  As Editable(Lighting) Byte
Dim LightHue		 As Editable(Lighting) Byte
Dim LightSaturation  As Editable(Lighting) Byte
Dim LightRadius		 As Editable(Lighting) Byte
Dim LightPeriod		 As Editable(Lighting) Byte
Dim LightPhase		 As Editable(Lighting) Byte
Dim LightCone		 As Editable(Lighting) Byte
Dim VolumeBrightness As Editable(Lighting) Byte
Dim VolumeRadius     As Editable(Lighting) Byte

' Internal flags.
Dim bStatic			 As Editable(Advanced) Boolean ' Actor does not move or change over time.
Dim bHidden			 As Editable(Advanced) Boolean ' Actor is hidden during gameplay.
Dim bHiddenEd		 As Editable(Advanced) Boolean ' Actor is hidden during editing.
Dim bDirectional	 As Editable(Advanced) Boolean ' Actor shows direction arrow during editing.
Dim bTemplateClass	 As Editable(Advanced) Boolean ' Don't instantiate actors of this base class.
Dim bSelected		 As Boolean                    ' This actor is selected in UnrealEd.
Dim bNoDelete		 As Boolean                    ' This actor cannot be deleted during play.
Dim bTempLightChanged As Boolean                   ' Recalculate this light's lighting now.
Dim bTempDynamicLight As Boolean                   ' Temporarily treat this as a dynamic light.

' User definable flags you can use for anything you want.
Dim bUser0          As Boolean
Dim bUser1          As Boolean
Dim bUser2          As Boolean
Dim bUser3          As Boolean
Dim bUser4          As Boolean
Dim bUser5          As Boolean
Dim bUser6          As Boolean
Dim bUser7          As Boolean

' Lighting related flags.
Dim bSpecialLit  	As Editable(Lighting) Boolean
Dim bOnHorizon		As Editable(Lighting) Boolean
Dim bActorShadows	As Boolean ' Actors in this light cast shadows [not implemented]

' Old flags.
Dim bAnimate 		As Editable(Animation) Boolean

' Rendering flags.
Dim bMeshWet		As Boolean ' Phong shaded mesh  [Not implemented]
Dim bMeshShadowCast As Boolean ' Mesh casts shadows [Not implemented]
Dim bMeshEnviroMap	As Boolean ' Mesh is environment mapped [Not implemented]
Dim bUnlit			As Editable(Display) Boolean
Dim bNoSmooth		As Editable(Display) Boolean

' Collision flags.
Dim bCollideActors	As Editable(Collision) Boolean
Dim bCollideWorld	As Editable(Collision) Boolean
Dim bBlocksActors	As Editable(Collision) Boolean
Dim bBlocksPlayers  As Editable(Collision) Boolean

' Player rendering flags
Dim bBehindView		As Boolean ' Outside-the-player view [Not implemented]

' Padding flags reserved for expansion.
Dim bPad0           As Boolean
Dim bPad1           As Boolean
Dim bPad2           As Boolean
Dim bPad3           As Boolean
Dim bPad4           As Boolean
Dim bPad5           As Boolean
Dim bPad6           As Boolean
Dim bPad7           As Boolean

'
' Variables used by the server and editor only.
'

' Identification.
Dim Name			  As Editable(Main) Name ' This actor's hardcoded name.
Dim Event    		  As Editable(Main) Name ' The event this actor causes.
Dim Zone			  As Byte                ' The zone the actor is in.

' Relationships.
Dim Me				  As Actor ' This actor.
Dim Target			  As Actor ' Actor we're aiming at (other uses as well).
Dim Inventory		  As Actor ' First actor in our inventory chain.
Dim Floor			  As Actor ' Moving brush actor we're standing on.

' Instigator helps to define responsibility for events. Say a player with
' a weapon shoots a projectile which causes a chain of 3 explosions which kills 
' a pawn. The Instigator is the player who started the chain of events.
Dim Instigator        As Actor ' The actor (usually a Pawn) which instigated this actor.

' Physics.
Dim Mass			  As Editable(Main) Real        ' Mass of this actor.
Dim WaterSinkRate     As Editable(Main) Real        ' Fraction of normal gravity. <0 means the object floats.
Dim bGravity		  As Editable(Main) Boolean     ' Automatic gravity support.
Dim bMomentum		  As Editable(Main) Boolean     ' Automatic momentum support.
Dim bDifficulty1	  As Editable(Main) Boolean
Dim bDifficulty2	  As Editable(Main) Boolean
Dim bDifficulty3	  As Editable(Main) Boolean
Dim bDifficulty4	  As Editable(Main) Boolean
Dim bNetCooperative   As Editable(Main) Boolean
Dim bNetDeathMatch	  As Editable(Main) Boolean
Dim bNetPersistent	  As Editable(Main) Boolean
Dim bNetNoMonsters	  As Editable(Main) Boolean
Dim bProjTarget		  As Editable(Advanced) Boolean ' Projectiles should target this actor.

' About this actor.
Dim bCanBeTeleported  As Editable(Main) Boolean     ' This actor can be teleported.
Dim bIsSecretGoal	  As Editable(Advanced) Boolean ' This actor counts in the "secret" total.
Dim bIsKillGoal		  As Editable(Advanced) Boolean ' This actor counts in the "death" toll
Dim bIsItemGoal		  As Editable(Advanced) Boolean ' This actor counts in the "item" count

' Internal stuff - don't mess with these in script code.
Dim TouchingActors(4) As Actor
Dim bWasTouchedByPlayer	As Boolean
Dim bSleeping		  As Boolean
Dim bTempEditor		  As Boolean
Dim bJustDeleted	  As Boolean

' Script execution.
Dim ScriptCountdown   As Byte    ' Counter for low-priority script execution
Dim ScriptTickRate    As Byte    ' Number of ticks between script update

' User timers.
Dim TimerCountdown    As Integer ' User timer event (ACTOR_Timer).
Dim TimerMessage      As Name    ' Parameterless Actor message to send when timer expires.

' UnrealEd related.
Dim DefaultEdCategory As Editable(Advanced) Name ' Default category to edit in UnrealEd.

' BlockedClasses and PassedClasses apply only if bBlocksActors=True.
'
' These arrays must be filled so that any used entries are in the first
' part of the array - the first null entry signals the end of the array.
' If BlockedClasses is empty, then it is assumed that Root is implicitly
' in BlockedClasses (which means that all classes are implicitly in 
' BlockedClasses).
'
' An non-player actor B is blocked by an actor A if:
'	(A.bBlocksActors=True), and 
'	(B is a kind of actor in BlockedClasses or BlockedClasses is empty), and
'	(B is not a kind of actor in PassedClasses).
'
' A player actor B is blocked by an actor A if:
'	(A.bBlocksPlayers=True).
'
Dim BlockedClasses(3) As Editable(Collision) Class ' Classes blocked by this actor.
Dim PassedClasses(3)  As Editable(Collision) Class ' Classes not blocked by this actor.

'<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
' ChanceOfExistence provides a simple way of randomly removing/inserting 
' an actor in the level. RandomizerDivider and RandomizerRemainder provide
' a more advanced way of synchronizing the randomization of two or more 
' actors by using a single random value for all actor randomization. 
' For example, if you want exactly one of three possible actors to appear, 
' set the RandomizerDivider value to 3 and the RandomizerRemainder
' values of the actors to 0, 1, and 2.
' You can combine both schemes.
Dim ChanceOfExistence   As Editable(Advanced) Byte  ' Probability (1-100%) that actor should be created. 0 means 100%
Dim RandomizerDivider   As Editable(Advanced) Byte  ' This is divided into a fixed random value (fixed for all actors) at level startup. 0 for no randomization.
Dim RandomizerRemainder As Editable(Advanced) Byte  ' If remainder of division (described in RandomizerDivider) is this, the actor exists.

Dim LifeSpan        As Editable(Advanced) Integer   ' How old the object lives before dying. 0 means undying. 
Dim Age             As Integer                      ' Age of object, in ticks.
Dim Era             As Integer                      ' Age of class-specific state, usually in ticks.

' Definitions of animation trigger events.
' We have 3 parallel arrays:
'   TriggerSequences(): Identifies the animation sequence (1...) or the texture sequence (1...)
'                If Sequences is not full, the last entry used should be followed by 0.
'                The sequence numbers must be sorted in non-decreasing order.
'   TriggerFrames(): Identifies a frame (1..) which has a trigger.
'   TriggerValues(): Identifies the trigger value
Dim TriggerSequences(10) As Editable(Animation) Byte
Dim TriggerFrames(10) As Editable(Animation) Byte
Dim TriggerValues(10) As Editable(Animation) Byte
Dim WhichTriggers     As Byte ' Which trigger sequence (1..) is currently in use. Index+1 into TriggerSequence. 0 for none.

Dim TextureList  As Integer                   ' Is really a pointer to a list of Textures
Dim TextureCount As Editable(Animation) Byte  ' Number of textures in TextureList

Dim AITask            As          EAI_Task ' AI task
Dim PendingTeleporter As Actor    ' Teleporter which actor has touched and is waiting to teleport (if bCanBeTeleported)
Dim TeleportDelay     As Byte     ' Countdown to next allowed teleportation
'>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=Actor
      Location=(X=+00000.000000,Y=+00000.000000,Z=+00000.000000)
      Velocity=(X=+00000.000000,Y=+00000.000000,Z=+00000.000000)
      DrawRot=(PITCH=0,YAW=0,ROLL=0)
      ViewRot=(PITCH=0,YAW=0,ROLL=0)
      Parent=None
      Weapon=None
      Texture=s_actor
      MeshMap=None
      Brush=None
      AmbientSound=None
      DrawScale=+00001.000000
      AnimRate=+00000.000000
      AnimBase=+00000.000000
      CollisionRadius=+00022.000000
      CollisionHeight=+00022.000000
      AnimSeq=0
      DrawType=1
      BlitType=1
      ParticleType=0
      ParticleCount=0
      ParticleRate=0
	  SoundRadius=32
      LightType=0
      LightEffect=0
      LightBrightness=0
      LightHue=0
      LightSaturation=0
      LightRadius=0
      LightPeriod=0
      LightPhase=0
      LightCone=0
      AmbientBrightness=0
      bAnimate=False
      bMeshSmooth=True
      bMeshWet=False
      bMeshShadowCast=False
      bMeshEnviroMap=False
      bEventSource=False
      bSpriteRotates=False
      bActorShadows=False
      bShinyReflect=False
      bSpecialLight=False
      bStatic=False
	  ScriptTickRate=1
      bHidden=False
      bHiddenEd=False
      bDirectional=False
      bCollideActors=False
      bCollideWorld=False
      bBlocksPlayers=False
      bBlocksActors=False
      bBehindView=False
      bSelected=False
      bTempDynamicLight=False
      bDrawOnHorizon=False
      bTemplateClass=True
      bUnused1=False
      bUnused2=False
      bUnused3=False
      bUnused4=False
      bUnused5=False
      bUnused6=False
      bLightIsAmbient=False
      Name=None
      EventName=None
      Target=None
      Inventory=None
      Mass=+00100.000000
      bInactive=False
      bPegged=False
      bGravity=False
      bMomentum=False
      bProjTarget=False
      bCanPossess=False
      bDifficulty1=True
      bDifficulty2=True
      bDifficulty3=True
      bDifficulty4=True
      bNetCooperative=True
      bNetDeathMatch=True
      bNetPersistent=True
      bNetNoMonsters=True
      bTempEditor=False
      bJustDeleted=False
