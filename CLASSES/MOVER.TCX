'
' Mover.
'

DeclareClass Name=Mover

Begin Class Name=Mover
   Begin Text
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
'
' The moving brush class.
' This is a built-in Unreal class and it shouldn't be modified.
'
Class Mover Expands Actor Intrinsic

' How the mover should react when it bumps into an actor.
EnumDef EMoverBumpType = MB_StopWhenBump, MB_ReturnWhenBump, _
   MB_CrushWhenBump

' How the mover should respond to Trigger/UnTrigger/Touch/UnTouch.
EnumDef EMoverTriggerType = MT_None, MT_TriggerOpenTimed, MT_TriggerToggle, _
   MT_TriggerControl, MT_TriggerCycleOn, MT_TriggerCycleOff, MT_TriggerInstant, _
   MT_ProximityOpenTimed, MT_ProximityControl, _
   MT_StandOpenTimed

' How the mover moves from one position to the other.
EnumDef EMoverGlideType = MV_MoveByTime, MV_GlideByTime, MV_Sinusoid

' Mover style.
Dim MoverBumpType    As Editable EMoverBumpType
Dim MoverTriggerType As Editable EMoverTriggerType
Dim MoverGlideType   As Editable EMoverGlideType

' Keyframes.
Dim KeyNum           As Editable Byte     ' Current (if still) or destination (if moving) keyframe.
Dim PrevKeyNum       As Byte              ' If moving, the previous keyframe.
Dim WorldRaytraceKey As Editable Byte     ' In UnrealEd, raytrace the world with the brush here.
Dim BrushRaytraceKey As Editable Byte     ' In UnrealEd, raytrace the brush here.

' Movement parameters.
Dim MoverTime        As Editable Integer  ' Time to spend moving between keyframes.
Dim RemainOpenTime   As Editable Integer  ' How long to remain open before closing.
Dim BumpPlayerDamage As Editable Real     ' How much to damage player if we bump him.
Dim FreeRotation     As Editable Rotation ' For freely rotating brushes.

' Mover flags.
Dim bCanInterruptMove As Editable Boolean ' Whether additional trigger msgs interrupt movement.
Dim bSlave           As Editable Boolean  ' This brush is a slave to its event.
Dim bTrigger         As Editable Boolean  ' This brush acts as a trigger.
Dim bMoving          As Boolean
Dim bReverseWhenDone As Boolean
Dim bTriggerOnceOnly As Editable Boolean

' Audio.
Dim OpenSound        As Editable Sound ' When hit full-open position
Dim ClosedSound      As Editable Sound ' When hit full-closed position
Dim MoveAmbientSound As Editable Sound ' Ambient sound when moving

' Array of 4 keyframe position offsets.
Dim KeyPos (4) as Vector
Dim KeyRot (4) as Rotation

' Base absolute location and rotation.

' Internal: Do not modify these by script.
Dim Slaves(16)   As Actor     ' List of actors standing on this brush.
Dim BasePos      As Vector    ' For interpolating movement.
Dim OldPos       As Vector    ' For interpolating movement.
Dim BaseRot      As Rotation  ' For interpolating movement.
Dim OldRot       As Rotation  ' For interpolating movement.
Dim CurTime      As Integer
Dim HoldTime     As Integer
Dim bAdded       As Boolean

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
   End Text
   Begin DefaultProperties
      Class=Mover
		Begin Brush Name=MoverDefaultBrush
		 Settings  CSG=0 Flags=64 PolyFlags=0 Color=0
		 Location  +00208.000000,-00384.000000,+00000.000000
